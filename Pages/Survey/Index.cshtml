@page
@model TINWeb.Pages.Survey.IndexModel
@{
    ViewData["Title"] = "Survey Records";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Survey Records</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="./Create" class="btn btn-primary">Add New Survey</a>
            <a asp-page="/CompanySurvey/Index" class="btn btn-outline-secondary ms-2">Company Surveys</a>
        </div>
    </div>

    @if (Model.Records.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Financial Year</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model.Records)
                {
                    <tr>
                        <td>@record.Id</td>
                        <td>@record.FinancialYear</td>
                        <td>
                            <a asp-page="./Details" asp-route-id="@record.Id" class="btn btn-sm btn-info">View</a>
                            <a asp-page="./Edit" asp-route-id="@record.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-page="./Delete" asp-route-id="@record.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No survey records found.</div>
    }
</div>
