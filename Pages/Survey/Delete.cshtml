@page "{id:int}"
@model TINWorkspaceTemp.Pages.Survey.DeleteModel
@{
    ViewData["Title"] = "Delete Survey";
}

<div class="container mt-4">
    <h1>Delete Survey</h1>
    <h3>Are you sure you want to delete this record?</h3>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Model.Record.Id</dd>

        <dt class="col-sm-3">Financial Year</dt>
        <dd class="col-sm-9">@Model.Record.FinancialYear</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Record.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
