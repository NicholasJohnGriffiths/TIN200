@page
@model TINWeb.Pages.Answers.IndexModel
@{
    ViewData["Title"] = "Answers by Company";
}

<div class="container-fluid px-0 mt-3">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="alert">
            @Model.StatusMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @Model.ErrorMessage
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Answers by Company Survey</h1>
            <p class="text-muted mb-0">Select a Company Survey record to view and edit its answers.</p>
            <p class="mb-0"><strong>Questions total:</strong> @Model.QuestionCount</p>
            <p class="mb-0"><strong>Rows shown:</strong> @Model.Rows.Count</p>
            <p class="mb-0"><strong>Answered:</strong> @Model.AnsweredCount</p>
        </div>
        <div class="col-md-4 text-end">
            <div class="d-inline-flex align-items-center gap-2 flex-wrap justify-content-end">
                <form method="post" asp-page-handler="PreviewImport" enctype="multipart/form-data" id="previewImportForm" class="d-inline-flex align-items-center gap-2">
                    <input type="hidden" name="financialYear" value="@Model.SelectedFinancialYear" />
                    <input type="file" name="importFile" accept=".xlsx" class="form-control form-control-sm" style="max-width: 220px;" />
                    <button type="submit" class="btn btn-outline-primary btn-sm">Preview Import</button>
                </form>

                <form method="post" asp-page-handler="PreviewGlobalImport" enctype="multipart/form-data" id="previewGlobalImportForm" class="d-inline-flex align-items-center gap-2">
                    <input type="hidden" name="financialYear" value="@Model.SelectedFinancialYear" />
                    <input type="file" name="importFile" accept=".xlsx" class="form-control form-control-sm" style="max-width: 220px;" />
                    <button type="submit" class="btn btn-outline-dark btn-sm">Import Global File</button>
                </form>

                <form method="post" asp-page-handler="CreateMissingAnswers" id="createMissingAnswersForm" class="d-inline">
                    <input type="hidden" name="financialYear" value="@Model.SelectedFinancialYear" />
                    <button type="submit" class="btn btn-outline-secondary btn-sm">Create Missing Answers</button>
                </form>

                <form method="get" asp-page="./Index" asp-page-handler="Export" id="answersExportForm" class="d-inline">
                    <input type="hidden" name="financialYear" value="@Model.SelectedFinancialYear" />
                    <button type="submit" class="btn btn-outline-success btn-sm">Export</button>
                </form>

                <form method="post" asp-page-handler="DeleteAllAnswers" id="deleteAllAnswersForm" class="d-inline">
                    <input type="hidden" name="deleteConfirmation" id="deleteConfirmationInput" />
                    <button type="button" class="btn btn-danger btn-sm" id="deleteAllAnswersButton">Delete All Answers</button>
                </form>
            </div>
        </div>
    </div>

    <div id="importProgressContainer" class="mb-3" style="display:none;">
        <div class="d-flex justify-content-between small mb-1">
            <span id="importProgressLabel">Import in progress...</span>
            <span id="importProgressPercent">0%</span>
        </div>
        <div class="progress" role="progressbar" aria-label="Import progress" aria-valuemin="0" aria-valuemax="100">
            <div id="importProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%"></div>
        </div>
    </div>

    @if (Model.ImportPreview != null)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title mb-3">Import Summary (FY @Model.ImportPreview.FinancialYear)</h5>
                <p class="mb-1"><strong>Records to add:</strong> @Model.ImportPreview.InsertedCount</p>
                <p class="mb-1"><strong>Records to update:</strong> @Model.ImportPreview.UpdatedCount</p>
                <p class="mb-1"><strong>Matched companies:</strong> @Model.ImportPreview.MatchedExternalIds.Count</p>
                <p class="mb-1"><strong>Non-matched companies:</strong> @Model.ImportPreview.UnmatchedExternalIds.Count</p>
                <p class="mb-1"><strong>Identifier match:</strong> @Model.ImportPreview.IdentifierFieldMatch</p>
                <p class="mb-3 text-warning"><strong>Company records to create on apply:</strong> @Model.ImportPreview.UnmatchedExternalIds.Count</p>

                @if (Model.ImportPreview.AvailableHeaders.Any())
                {
                    <p class="mb-1"><strong>Detected headers (row 2):</strong></p>
                    <div class="small text-muted mb-3">@string.Join(", ", Model.ImportPreview.AvailableHeaders)</div>
                }

                @if (Model.ImportPreview.MatchedFields.Any())
                {
                    <p class="mb-1"><strong>Matched question fields:</strong></p>
                    <ul class="small text-muted mb-3">
                        @foreach (var matchedField in Model.ImportPreview.MatchedFields.Take(30))
                        {
                            <li>@matchedField</li>
                        }
                    </ul>
                }

                @if (Model.ImportPreview.UnmatchedFields.Any())
                {
                    <p class="mb-1 text-warning"><strong>Unmatched question fields:</strong></p>
                    <ul class="small text-warning mb-3">
                        @foreach (var unmatchedField in Model.ImportPreview.UnmatchedFields.Take(30))
                        {
                            <li>@unmatchedField</li>
                        }
                    </ul>
                }

                @if (Model.ImportPreview.MatchedExternalIds.Any())
                {
                    <p class="mb-1"><strong>Matched External IDs:</strong></p>
                    <div class="small text-muted mb-3">@string.Join(", ", Model.ImportPreview.MatchedExternalIds)</div>
                }

                @if (Model.ImportPreview.UnmatchedExternalIds.Any())
                {
                    <p class="mb-1 text-warning"><strong>External IDs not found in Company table (will be created):</strong></p>
                    <div class="small text-danger mb-3">@string.Join(", ", Model.ImportPreview.UnmatchedExternalIds)</div>
                }

                @if (Model.ImportPreview.Errors.Any())
                {
                    <p class="mb-1 text-danger"><strong>Preview errors:</strong></p>
                    <ul class="small text-danger mb-3">
                        @foreach (var error in Model.ImportPreview.Errors.Take(10))
                        {
                            <li>@error</li>
                        }
                    </ul>
                }

                <form method="post" asp-page-handler="ApplyImport" id="applyImportForm" class="d-inline">
                    <input type="hidden" name="previewToken" value="@Model.PendingImportToken" />
                    <button type="submit" class="btn btn-primary">Apply Import</button>
                </form>
            </div>
        </div>
    }

    @if (Model.GlobalImportPreview != null)
    {
        <div class="card mb-3 border-dark">
            <div class="card-body">
                <h5 class="card-title mb-3">Global Import Summary (FY @Model.GlobalImportPreview.FinancialYear)</h5>
                <p class="mb-1"><strong>Records to add:</strong> @Model.GlobalImportPreview.InsertedCount</p>
                <p class="mb-1"><strong>Records to update:</strong> @Model.GlobalImportPreview.UpdatedCount</p>
                <p class="mb-1"><strong>Matched rows:</strong> @Model.GlobalImportPreview.MatchedExternalIds.Count</p>
                <p class="mb-1"><strong>Unmatched rows:</strong> @Model.GlobalImportPreview.UnmatchedExternalIds.Count</p>
                <p class="mb-1"><strong>Skipped (already submitted):</strong> @Model.GlobalImportPreview.SkippedSubmittedRowKeys.Count</p>
                <p class="mb-1"><strong>Identifier match:</strong> @Model.GlobalImportPreview.IdentifierFieldMatch</p>
                <p class="mb-3 text-muted">Matching used: Excel <strong>ID</strong> to Company <strong>ExternalId</strong>, then fallback Excel <strong>Name</strong> to Company <strong>CompanyName</strong>. Question columns matched by <strong>ImportColumnNameAlt</strong>.</p>

                @if (Model.GlobalImportPreview.AvailableHeaders.Any())
                {
                    <p class="mb-1"><strong>Detected headers (row 1):</strong></p>
                    <div class="small text-muted mb-3">@string.Join(", ", Model.GlobalImportPreview.AvailableHeaders)</div>
                }

                @if (Model.GlobalImportPreview.MatchedFields.Any())
                {
                    <p class="mb-1"><strong>Matched question fields (@Model.GlobalImportPreview.MatchedFields.Count):</strong></p>
                    <ul class="small text-muted mb-3">
                        @foreach (var matchedField in Model.GlobalImportPreview.MatchedFields)
                        {
                            <li>@matchedField</li>
                        }
                    </ul>
                }

                @if (Model.GlobalImportPreview.UnmatchedFields.Any())
                {
                    <p class="mb-1 text-warning"><strong>Unmatched question fields (@Model.GlobalImportPreview.UnmatchedFields.Count):</strong></p>
                    <ul class="small text-warning mb-3">
                        @foreach (var unmatchedField in Model.GlobalImportPreview.UnmatchedFields)
                        {
                            <li>@unmatchedField</li>
                        }
                    </ul>
                }

                @if (Model.GlobalImportPreview.UnmatchedExternalIds.Any())
                {
                    <p class="mb-1 text-warning"><strong>Unmatched row keys (ID|Name):</strong></p>
                    <div class="small text-danger mb-3">@string.Join(", ", Model.GlobalImportPreview.UnmatchedExternalIds.Take(50))</div>
                }

                @if (Model.GlobalImportPreview.SkippedSubmittedRowKeys.Any())
                {
                    <p class="mb-1 text-warning"><strong>Skipped row keys (already submitted for selected year):</strong></p>
                    <div class="small text-warning mb-3">@string.Join(", ", Model.GlobalImportPreview.SkippedSubmittedRowKeys.Take(50))</div>
                }

                @if (Model.GlobalImportPreview.Errors.Any())
                {
                    <p class="mb-1 text-danger"><strong>Preview errors:</strong></p>
                    <ul class="small text-danger mb-3">
                        @foreach (var error in Model.GlobalImportPreview.Errors.Take(10))
                        {
                            <li>@error</li>
                        }
                    </ul>
                }

                <form method="post" asp-page-handler="ApplyGlobalImport" id="applyGlobalImportForm" class="d-inline">
                    <input type="hidden" name="previewToken" value="@Model.PendingGlobalImportToken" />
                    <button type="submit" class="btn btn-dark">Apply Global Import</button>
                </form>
            </div>
        </div>
    }

    <div class="row mb-3">
        <div class="col-12">
            <form method="get" class="d-flex flex-wrap gap-2 align-items-center">
                <label class="me-1">Financial Year:</label>
                <select name="financialYear" class="form-select" aria-label="Financial Year" style="max-width: 180px;">
                    <option value="">All</option>
                    @foreach (var year in Model.FinancialYears)
                    {
                        <option value="@year" selected="@(Model.SelectedFinancialYear == year ? "selected" : null)">@year</option>
                    }
                </select>

                <label class="ms-2 me-1">Company Survey:</label>
                <select name="companySurveyId" class="form-select" aria-label="Company Survey" style="max-width: 980px; min-width: 760px;">
                    <option value="">Select Company Survey</option>
                    @foreach (var option in Model.CompanySurveyOptions)
                    {
                        var savedDate = option.SavedDate?.ToString("dd/MM/yyyy") ?? string.Empty;
                        var submittedDate = option.SubmittedDate?.ToString("dd/MM/yyyy") ?? string.Empty;
                        var requestedDate = option.RequestedDate?.ToString("dd/MM/yyyy") ?? string.Empty;
                        <option value="@option.CompanySurveyId" selected="@(Model.SelectedCompanySurveyId == option.CompanySurveyId ? "selected" : null)">
                            CompanySurvey: #@option.CompanySurveyId | @option.CompanyName | FY: @option.FinancialYear | Answers: @option.AnswerCount | SavedDate: @savedDate | SubmittedDate: @submittedDate | RequestedDate: @requestedDate
                        </option>
                    }
                </select>

                <button class="btn btn-outline-primary" type="submit">Apply</button>
                <a class="btn btn-link ms-2" asp-page="./Index">Clear</a>
            </form>
        </div>
    </div>

    @if (!Model.SelectedCompanySurveyId.HasValue)
    {
        <div class="alert alert-info">Select a Company Survey record to view answers.</div>
    }
    else if (Model.Rows.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover company-table answers-table">
                <thead class="table-dark">
                    <tr>
                        <th>Company</th>
                        <th>Year</th>
                        <th>Order</th>
                        <th>Question</th>
                        <th>Answer</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    var answerType = (row.AnswerType ?? string.Empty).Trim();
                    var isBoolean = answerType.Equals("Boolean", StringComparison.OrdinalIgnoreCase)
                        || answerType.Equals("Bool", StringComparison.OrdinalIgnoreCase);

                    string answerValue;
                    if (isBoolean)
                    {
                        var normalizedText = (row.AnswerText ?? string.Empty).Trim();
                        if (!string.IsNullOrWhiteSpace(normalizedText))
                        {
                            if (normalizedText == "1"
                                || normalizedText.Equals("true", StringComparison.OrdinalIgnoreCase)
                                || normalizedText.Equals("yes", StringComparison.OrdinalIgnoreCase))
                            {
                                answerValue = "Yes";
                            }
                            else if (normalizedText == "0"
                                || normalizedText.Equals("false", StringComparison.OrdinalIgnoreCase)
                                || normalizedText.Equals("no", StringComparison.OrdinalIgnoreCase))
                            {
                                answerValue = "No";
                            }
                            else
                            {
                                answerValue = normalizedText;
                            }
                        }
                        else if (row.AnswerNumber.HasValue)
                        {
                            if (Math.Abs(row.AnswerNumber.Value - 1d) < 0.0000001)
                            {
                                answerValue = "Yes";
                            }
                            else if (Math.Abs(row.AnswerNumber.Value) < 0.0000001)
                            {
                                answerValue = "No";
                            }
                            else
                            {
                                answerValue = row.AnswerNumber.Value.ToString();
                            }
                        }
                        else
                        {
                            answerValue = row.AnswerCurrency.HasValue
                                ? row.AnswerCurrency.Value.ToString("C")
                                : string.Empty;
                        }
                    }
                    else
                    {
                        answerValue = !string.IsNullOrWhiteSpace(row.AnswerText)
                            ? row.AnswerText
                            : row.AnswerNumber.HasValue
                                ? row.AnswerNumber.Value.ToString()
                                : row.AnswerCurrency.HasValue
                                    ? row.AnswerCurrency.Value.ToString("C")
                                    : string.Empty;
                    }

                    <tr>
                        <td>@row.CompanyName</td>
                        <td>@row.FinancialYear</td>
                        <td>@row.QuestionOrderNumber</td>
                        <td>@row.QuestionText</td>
                        <td>@answerValue</td>
                        <td>
                            @if (row.Id > 0)
                            {
                                <a asp-page="./Edit" asp-route-id="@row.Id" class="btn btn-sm btn-warning">Edit</a>
                            }
                            else
                            {
                                <span class="text-muted">No answer</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No answers found for the selected Company Survey.</div>
    }
</div>

<script>
    (function () {
        const progressContainer = document.getElementById('importProgressContainer');
        const progressBar = document.getElementById('importProgressBar');
        const progressPercent = document.getElementById('importProgressPercent');
        const progressLabel = document.getElementById('importProgressLabel');
        const previewImportForm = document.getElementById('previewImportForm');
        const previewGlobalImportForm = document.getElementById('previewGlobalImportForm');
        const applyImportForm = document.getElementById('applyImportForm');
        const applyGlobalImportForm = document.getElementById('applyGlobalImportForm');
        const createMissingAnswersForm = document.getElementById('createMissingAnswersForm');
        const answersExportForm = document.getElementById('answersExportForm');

        let timerId = null;

        function startProgress(labelText) {
            if (!progressContainer || !progressBar || !progressPercent || !progressLabel) {
                return;
            }

            if (timerId) {
                window.clearInterval(timerId);
            }

            let value = 8;
            progressLabel.textContent = labelText;
            progressContainer.style.display = '';

            function render() {
                progressBar.style.width = value + '%';
                progressPercent.textContent = value + '%';
            }

            render();

            timerId = window.setInterval(function () {
                if (value < 90) {
                    value += 4;
                    render();
                }
            }, 250);
        }

        function wire(form, label) {
            if (!form) {
                return;
            }

            form.addEventListener('submit', function () {
                startProgress(label);
            });
        }

        wire(previewImportForm, 'Previewing import file...');
        wire(previewGlobalImportForm, 'Previewing global import file...');
        wire(applyImportForm, 'Applying import...');
        wire(applyGlobalImportForm, 'Applying global import...');
        wire(createMissingAnswersForm, 'Creating missing answers...');
        wire(answersExportForm, 'Exporting answers...');
    })();

    (function () {
        const button = document.getElementById('deleteAllAnswersButton');
        const form = document.getElementById('deleteAllAnswersForm');
        const confirmationInput = document.getElementById('deleteConfirmationInput');

        if (!button || !form || !confirmationInput) {
            return;
        }

        button.addEventListener('click', function () {
            const acknowledged = window.confirm('WARNING: This will permanently delete all data in the Answer table and recreate the table, constraints, and indexes. This cannot be undone. Click OK to continue.');
            if (!acknowledged) {
                return;
            }

            const typed = window.prompt('Type delete to confirm this action.');
            if (typed === null) {
                return;
            }

            confirmationInput.value = typed;
            form.submit();
        });
    })();
</script>

