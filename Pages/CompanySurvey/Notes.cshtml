@page
@model TINWeb.Pages.CompanySurvey.NotesModel
@{
    ViewData["Title"] = "Company Survey Notes";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Company Survey Notes</h1>
            <p class="text-muted mb-0">
                Company Survey ID: <strong>@Model.CompanySurveyId</strong>
                @if (!string.IsNullOrWhiteSpace(Model.CompanyName))
                {
                    <span> | @Model.CompanyName</span>
                }
            </p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">Add Note</div>
        <div class="card-body">
            <form method="post">
                <input type="hidden" name="companySurveyId" value="@Model.CompanySurveyId" />
                <input type="hidden" name="financialYear" value="@Model.FinancialYear" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="mb-3">
                    <label asp-for="NewNoteText" class="form-label">Note</label>
                    <textarea asp-for="NewNoteText" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="NewNoteText" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Save Note</button>
                <a asp-page="./Index" asp-route-financialYear="@Model.FinancialYear" class="btn btn-secondary">Back to Company Survey Records</a>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Saved Notes</div>
        <div class="card-body p-0">
            @if (Model.Notes.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 220px;">Date/Time</th>
                                <th style="width: 220px;">User</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var note in Model.Notes)
                            {
                                <tr>
                                    <td>@note.NoteDateTime.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td>@note.User</td>
                                    <td style="white-space: pre-wrap;">@note.Notes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 text-muted">No notes have been saved for this company survey yet.</div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
