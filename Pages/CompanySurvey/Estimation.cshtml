            <div class="small text-muted">@Model.RegionalEmploymentForecastReason</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.RegionalEmploymentForecastReason))
    {
        <div class="alert alert-warning mt-3">
            <div><strong>Forecasted Regional Employment (@Model.SelectedRegionalEmploymentRegionLabel):</strong> not available</div>
            <div class="small text-muted">@Model.RegionalEmploymentForecastReason</div>
        </div>
    }

    @if (Model.ForecastedWages.HasValue)
    {
        <div class="alert alert-success mt-3">
            <div><strong>Forecasted Wages & Salaries:</strong> @Model.ForecastedWages.Value.ToString("N2")</div>
            <div class="small text-muted">@Model.WagesForecastReason</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.WagesForecastReason))
