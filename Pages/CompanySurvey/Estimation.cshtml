@page
@model TINWeb.Pages.CompanySurvey.EstimationModel
@{
    ViewData["Title"] = "Company Survey Estimation";
}

<style>
    .estimation-header {
        gap: 0.5rem;
    }

    .estimation-preview-card {
        border-top: 1px solid rgba(0, 0, 0, 0.08);
        background: #f8f9fa;
    }

    .estimation-preview-info {
        background-color: #e7f5ff;
        color: #084298;
    }

    .estimation-preview-used {
        background-color: #d1e7dd;
        color: #0f5132;
        font-weight: 600;
    }

    .estimation-generate-btn {
        white-space: nowrap;
    }

    .estimation-check-btn {
        white-space: nowrap;
    }

    .estimation-manual-input {
        width: 160px;
        min-width: 120px;
    }

    .btn-label-short {
        display: none;
    }

    @@media (max-width: 768px) {
        .estimation-header {
            flex-wrap: wrap;
            align-items: flex-start !important;
        }

        .estimation-header span {
            flex: 1 1 100%;
            line-height: 1.25;
        }

        .estimation-header form {
            margin-left: 0;
        }

        .estimation-generate-btn {
            font-size: 0.75rem;
            padding: 0.2rem 0.5rem;
        }

        .estimation-check-btn {
            font-size: 0.75rem;
            padding: 0.2rem 0.5rem;
        }

        .estimation-manual-input {
            width: 120px;
        }

        .estimation-generate-btn .btn-label-full {
            display: none;
        }

        .estimation-generate-btn .btn-label-short {
            display: inline;
        }
    }
</style>

<div class="container mt-4" data-target-financial-year="@Model.TargetFinancialYear" data-check-metric-key="@Model.CheckMetricKey" data-check-has-value="@(Model.CheckSelectedValue.HasValue ? "true" : "false")" data-check-selected-value="@(Model.CheckSelectedValue.HasValue ? Model.CheckSelectedValue.Value.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) : string.Empty)" data-check-region-question-title="@Model.SelectedRegionalEmploymentQuestionTitle">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Company Survey Estimation</h1>
            <p class="text-muted mb-0">
                Company: <strong>@Model.CompanyName</strong> |
                Company Survey ID: <strong>@Model.CompanySurveyId</strong> |
                Target Financial Year: <strong>@Model.TargetFinancialYear</strong>
            </p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center estimation-header">
            <span>Last 5 Years - Total Revenue Last Financial Year</span>
            @if (Model.EstimateEnabled && !Model.IsLocked)
            {
                <form method="post" asp-page-handler="CalculateRevenue" class="mb-0">
                    <input type="hidden" name="companySurveyId" value="@Model.CompanySurveyId" />
                    <input type="hidden" name="financialYear" value="@Model.FinancialYearFilter" />
                    <button type="submit" class="btn btn-sm btn-outline-success estimation-generate-btn"><span class="btn-label-full">Generate</span><span class="btn-label-short">Gen</span></button>
                </form>
            }
        </div>
        <div class="card-body p-0">
            @if (Model.LastFiveYearsRevenue.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 200px;">Financial Year</th>
                                <th style="width: 220px;">Company Survey ID</th>
                                <th>Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.LastFiveYearsRevenue)
                            {
                                <tr>
                                    <td>@row.FinancialYear</td>
                                    <td>@row.CompanySurveyId</td>
                                    <td>@(row.Value?.ToString("N2") ?? string.Empty)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 text-muted">No historical revenue values were found for this company.</div>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center estimation-header">
            <span>Last 5 Years - Total Employment Last Financial Year</span>
            @if (Model.EstimateEnabled && !Model.IsLocked)
            {
                <form method="post" asp-page-handler="CalculateEmployment" class="mb-0">
                    <input type="hidden" name="companySurveyId" value="@Model.CompanySurveyId" />
                    <input type="hidden" name="financialYear" value="@Model.FinancialYearFilter" />
                    <button type="submit" class="btn btn-sm btn-outline-success estimation-generate-btn"><span class="btn-label-full">Generate</span><span class="btn-label-short">Gen</span></button>
                </form>
            }
        </div>
        <div class="card-body p-0">
            @if (Model.LastFiveYearsEmployment.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 200px;">Financial Year</th>
                                <th style="width: 220px;">Company Survey ID</th>
                                <th>Employment Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.LastFiveYearsEmployment)
                            {
                                <tr>
                                    <td>@row.FinancialYear</td>
                                    <td>@row.CompanySurveyId</td>
                                    <td>@(row.Value?.ToString("N2") ?? string.Empty)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 text-muted">No historical employment values were found for this company.</div>
            }
        </div>
    </div>

    @if (!Model.AvailableRegionalEmploymentQuestionTitles.Any())
    {
        <div class="card mb-4">
            <div class="card-header">Regional Employment Estimation</div>
            <div class="card-body">
                <div class="text-muted">No Regional Employment questions were found in the question set.</div>
            </div>
        </div>
    }
    else
    {
        var domesticRegionLabels = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "Northland", "Auckland", "Waikato", "BOP", "Gisborne", "HB", "Taranaki", "Wanganui", "Wgtn", "Manawatu", "Nelson", "Marlborough", "Canterbury", "WestCoast", "Otago", "Southland"
        };
        string RegionLabel(string questionTitle) => questionTitle.Replace("Regional Employment ", string.Empty).Replace(" Last Financial Year", string.Empty).Trim();
        var globalRegionalQuestions = Model.AvailableRegionalEmploymentQuestionTitles.Where(q => !domesticRegionLabels.Contains(RegionLabel(q))).ToList();
        var domesticRegionalQuestions = Model.AvailableRegionalEmploymentQuestionTitles.Where(q => domesticRegionLabels.Contains(RegionLabel(q))).ToList();

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Regional Employment - Global Regions</span>
                <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#regionalEmploymentGlobal" aria-expanded="true" aria-controls="regionalEmploymentGlobal">Toggle</button>
            </div>
            <div id="regionalEmploymentGlobal" class="collapse show">
                <div class="card-body">
                    @if (!globalRegionalQuestions.Any())
                    {
                        <div class="text-muted">No global regional employment questions found.</div>
                    }
                    else
                    {
                        @foreach (var regionalQuestionTitle in globalRegionalQuestions)
                        {
                            var regionLabel = RegionLabel(regionalQuestionTitle);
                            var regionalRows = Model.LastFiveYearsRegionalEmploymentByQuestionTitle.TryGetValue(regionalQuestionTitle, out var rows)
                                ? rows
                                : new List<TINWeb.Pages.CompanySurvey.EstimationModel.MetricHistoryRow>();

                            <div class="card mb-3">
                                <div class="card-header d-flex justify-content-between align-items-center estimation-header">
                                    <span>Last 5 Years - @regionalQuestionTitle</span>
                                    @if (Model.EstimateEnabled && !Model.IsLocked)
                                    {
                                        <form method="post" asp-page-handler="CalculateRegionalEmployment" class="mb-0">
                                            <input type="hidden" name="companySurveyId" value="@Model.CompanySurveyId" />
                                            <input type="hidden" name="financialYear" value="@Model.FinancialYearFilter" />
                                            <input type="hidden" name="regionQuestionTitle" value="@regionalQuestionTitle" />
                                            <button type="submit" class="btn btn-sm btn-outline-success estimation-generate-btn"><span class="btn-label-full">Generate</span><span class="btn-label-short">Gen</span></button>
                                        </form>
                                    }
                                </div>
                                <div class="card-body p-0">
                                    @if (regionalRows.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-striped mb-0">
                                                <thead class="table-dark">
                                                    <tr>
                                                        <th style="width: 200px;">Financial Year</th>
                                                        <th style="width: 220px;">Company Survey ID</th>
                                                        <th>Regional Employment (@regionLabel)</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var row in regionalRows)
                                                    {
                                                        <tr>
                                                            <td>@row.FinancialYear</td>
                                                            <td>@row.CompanySurveyId</td>
                                                            <td>@(row.Value?.ToString("N2") ?? string.Empty)</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="p-3 text-muted">No historical regional employment values were found for @regionLabel.</div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Regional Employment - NZ Domestic Regions</span>
                <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#regionalEmploymentDomestic" aria-expanded="false" aria-controls="regionalEmploymentDomestic">Toggle</button>
            </div>
            <div id="regionalEmploymentDomestic" class="collapse">
                <div class="card-body">
                    @if (!domesticRegionalQuestions.Any())
                    {
                        <div class="text-muted">No NZ domestic regional employment questions found.</div>
                    }
                    else
                    {
                        @foreach (var regionalQuestionTitle in domesticRegionalQuestions)
                        {
                            var regionLabel = RegionLabel(regionalQuestionTitle);
                            var regionalRows = Model.LastFiveYearsRegionalEmploymentByQuestionTitle.TryGetValue(regionalQuestionTitle, out var rows)
                                ? rows
                                : new List<TINWeb.Pages.CompanySurvey.EstimationModel.MetricHistoryRow>();

                            <div class="card mb-3">
                                <div class="card-header d-flex justify-content-between align-items-center estimation-header">
                                    <span>Last 5 Years - @regionalQuestionTitle</span>
                                    @if (Model.EstimateEnabled && !Model.IsLocked)
                                    {
                                        <form method="post" asp-page-handler="CalculateRegionalEmployment" class="mb-0">
                                            <input type="hidden" name="companySurveyId" value="@Model.CompanySurveyId" />
                                            <input type="hidden" name="financialYear" value="@Model.FinancialYearFilter" />
                                            <input type="hidden" name="regionQuestionTitle" value="@regionalQuestionTitle" />
                                            <button type="submit" class="btn btn-sm btn-outline-success estimation-generate-btn"><span class="btn-label-full">Generate</span><span class="btn-label-short">Gen</span></button>
                                        </form>
                                    }
                                </div>
                                <div class="card-body p-0">
                                    @if (regionalRows.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-striped mb-0">
                                                <thead class="table-dark">
                                                    <tr>
                                                        <th style="width: 200px;">Financial Year</th>
                                                        <th style="width: 220px;">Company Survey ID</th>
                                                        <th>Regional Employment (@regionLabel)</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var row in regionalRows)
                                                    {
                                                        <tr>
                                                            <td>@row.FinancialYear</td>
                                                            <td>@row.CompanySurveyId</td>
                                                            <td>@(row.Value?.ToString("N2") ?? string.Empty)</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="p-3 text-muted">No historical regional employment values were found for @regionLabel.</div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }

