                    <input type="hidden" name="revenueAustraliaForecastReason" value="@Model.RevenueAustraliaForecastReason" />
                    <input type="hidden" name="forecastedRevenueAustralia" value="@Model.ForecastedRevenueAustralia" />
                    <input type="hidden" name="revenueChinaForecastReason" value="@Model.RevenueChinaForecastReason" />
                    <input type="hidden" name="forecastedRevenueChina" value="@Model.ForecastedRevenueChina" />
                    <input type="hidden" name="revenueRestOfAsiaForecastReason" value="@Model.RevenueRestOfAsiaForecastReason" />
                    <input type="hidden" name="forecastedRevenueRestOfAsia" value="@Model.ForecastedRevenueRestOfAsia" />
                    <input type="hidden" name="revenueNorthAmericaForecastReason" value="@Model.RevenueNorthAmericaForecastReason" />
                    <input type="hidden" name="forecastedRevenueNorthAmerica" value="@Model.ForecastedRevenueNorthAmerica" />
                    <input type="hidden" name="revenueEuropeForecastReason" value="@Model.RevenueEuropeForecastReason" />
                    <input type="hidden" name="forecastedRevenueEurope" value="@Model.ForecastedRevenueEurope" />
                    <input type="hidden" name="revenueMiddleEastForecastReason" value="@Model.RevenueMiddleEastForecastReason" />
                    <input type="hidden" name="forecastedRevenueMiddleEast" value="@Model.ForecastedRevenueMiddleEast" />
                    <input type="hidden" name="revenueLatinAmericaForecastReason" value="@Model.RevenueLatinAmericaForecastReason" />
                    <input type="hidden" name="forecastedRevenueLatinAmerica" value="@Model.ForecastedRevenueLatinAmerica" />
                    <input type="hidden" name="revenueAfricaForecastReason" value="@Model.RevenueAfricaForecastReason" />
                    <input type="hidden" name="forecastedRevenueAfrica" value="@Model.ForecastedRevenueAfrica" />
                    <input type="hidden" name="revenueOtherForecastReason" value="@Model.RevenueOtherForecastReason" />
                    <input type="hidden" name="forecastedRevenueOther" value="@Model.ForecastedRevenueOther" />
                    <button type="submit" class="btn btn-primary">Save</button>
                </form>

                <form method="post" asp-page-handler="CancelEstimation" class="d-inline ms-2">
                    <input type="hidden" name="companySurveyId" value="@Model.CompanySurveyId" />
                    <input type="hidden" name="financialYear" value="@Model.FinancialYearFilter" />
                    <button type="submit" class="btn btn-outline-secondary">Cancel</button>
                </form>
            </div>
        </div>
    }
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        (function () {
            function isValidManualValue(raw) {
                if (raw === null || raw === undefined) {
                    return false;
                }

                var value = raw.trim();
                if (!value) {
                    return false;
                }

                var normalized = value.replace(/,/g, '');
                var parsed = Number(normalized);
                if (!Number.isFinite(parsed) || parsed < 0) {
                    return false;
                }

                var decimalParts = normalized.split('.');
                if (decimalParts.length > 2) {
                    return false;
                }

                return decimalParts.length === 1 || decimalParts[1].length <= 2;
            }

            function updateApplyState(form, manualInput) {
                var applyButton = form.querySelector('.estimation-generate-btn');
                if (!applyButton) {
                    return;
                }

                var manualRaw = manualInput ? manualInput.value : '';
                var manualHasValue = manualRaw.trim().length > 0;
                var manualValid = isValidManualValue(manualRaw);
                var logicValid = form.getAttribute('data-logic-valid') === 'true';

                if (manualInput) {
                    manualInput.classList.toggle('is-invalid', manualHasValue && !manualValid);
                }

                applyButton.disabled = !((manualHasValue && manualValid) || (!manualHasValue && logicValid));
            }

            function formatToTwoDecimals(raw) {
                if (raw === null || raw === undefined) {
                    return '';
                }

                var normalized = String(raw).trim().replace(/,/g, '');
                if (!normalized) {
                    return '';
                }

                var parsed = Number(normalized);
                if (!Number.isFinite(parsed) || parsed < 0) {
                    return '';
                }

                return parsed.toFixed(2);
            }

            document.addEventListener('DOMContentLoaded', function () {
                var container = document.querySelector('.container[data-target-financial-year]');
                var checkedMetricKey = container ? (container.getAttribute('data-check-metric-key') || '') : '';
                var checkedHasValue = container ? (container.getAttribute('data-check-has-value') === 'true') : false;
                var checkedSelectedValue = container ? (container.getAttribute('data-check-selected-value') || '') : '';
                var checkedRegionQuestionTitle = container ? (container.getAttribute('data-check-region-question-title') || '') : '';
                var previewCard = document.querySelector('.estimation-preview-global');
                var previewMoved = false;

                var headers = Array.from(document.querySelectorAll('.card-header.estimation-header'));
                headers.forEach(function (header) {
                    var generateForm = header.querySelector('form');
                    if (!generateForm || header.querySelector('.estimation-check-btn')) {
                        return;
                    }

                    var action = generateForm.getAttribute('action') || '';
                    var actionUrl = new URL(action || window.location.href, window.location.origin);
                    var metricKey = actionUrl.searchParams.get('handler') || '';
                    if (metricKey.startsWith('Calculate')) {
                        metricKey = metricKey.substring('Calculate'.length);
                    }

                    generateForm.action = '?handler=Apply';
                    generateForm.setAttribute('data-metric-key', metricKey);
                    generateForm.classList.add('d-flex', 'align-items-center', 'gap-2', 'mb-0');

                    var metricField = generateForm.querySelector('input[name="metricKey"]');
                    if (!metricField) {
                        metricField = document.createElement('input');
                        metricField.type = 'hidden';
                        metricField.name = 'metricKey';
                        generateForm.appendChild(metricField);
                    }
                    metricField.value = metricKey;

                    var applyButton = generateForm.querySelector('.estimation-generate-btn');
                    if (applyButton) {
                        applyButton.innerHTML = '<span class="btn-label-full">Apply</span><span class="btn-label-short">Apply</span>';
                    }

                    var manualInput = generateForm.querySelector('input[name="manualValue"]');
                    if (!manualInput) {
                        manualInput = document.createElement('input');
                        manualInput.type = 'text';
                        manualInput.name = 'manualValue';
                        manualInput.placeholder = 'Manual value';
                        manualInput.setAttribute('inputmode', 'decimal');
                        manualInput.setAttribute('title', 'Enter a number with up to 2 decimal places.');
                        manualInput.className = 'form-control form-control-sm estimation-manual-input';
                        generateForm.insertBefore(manualInput, applyButton || null);
                    }

                    var regionInput = generateForm.querySelector('input[name="regionQuestionTitle"]');
                    var regionQuestionTitle = regionInput ? regionInput.value : '';
                    var isMatchingCheckedMetric = metricKey === checkedMetricKey
                        && ((metricKey !== 'RegionalEmployment') || regionQuestionTitle === checkedRegionQuestionTitle);

                    if (isMatchingCheckedMetric && checkedHasValue && checkedSelectedValue) {
                        manualInput.value = formatToTwoDecimals(checkedSelectedValue);
                    }

                    var logicValid = isMatchingCheckedMetric && checkedHasValue;
                    generateForm.setAttribute('data-logic-valid', logicValid ? 'true' : 'false');
                    updateApplyState(generateForm, manualInput);

                    if (previewCard && isMatchingCheckedMetric && !previewMoved) {
                        var card = header.closest('.card');
                        if (card) {
                            card.insertAdjacentElement('afterend', previewCard);
                            previewMoved = true;
                        }
                    }

                    manualInput.addEventListener('input', function () {
                        updateApplyState(generateForm, manualInput);
                    });

                    var checkButton = document.createElement('button');
                    checkButton.type = 'button';
                    checkButton.className = 'btn btn-sm btn-outline-primary estimation-check-btn';
                    checkButton.textContent = 'Check';
                    checkButton.addEventListener('click', function () {
                        var companySurveyInput = generateForm.querySelector('input[name="companySurveyId"]');
                        if (!companySurveyInput) {
                            return;
                        }

                        var postForm = document.createElement('form');
                        postForm.method = 'post';
                        postForm.action = '?handler=Check';

                        var antiForgery = document.querySelector('input[name="__RequestVerificationToken"]');
                        if (antiForgery) {
                            var tokenInput = document.createElement('input');
                            tokenInput.type = 'hidden';
                            tokenInput.name = '__RequestVerificationToken';
                            tokenInput.value = antiForgery.value;
                            postForm.appendChild(tokenInput);
                        }

                        var companySurveyField = document.createElement('input');
                        companySurveyField.type = 'hidden';
                        companySurveyField.name = 'companySurveyId';
                        companySurveyField.value = companySurveyInput.value;
                        postForm.appendChild(companySurveyField);

                        var yearInput = generateForm.querySelector('input[name="financialYear"]');
                        if (yearInput) {
                            var yearField = document.createElement('input');
                            yearField.type = 'hidden';
                            yearField.name = 'financialYear';
                            yearField.value = yearInput.value;
                            postForm.appendChild(yearField);
                        }

                        var metricField = document.createElement('input');
                        metricField.type = 'hidden';
                        metricField.name = 'metricKey';
                        metricField.value = metricKey;
                        postForm.appendChild(metricField);

                        var regionInput = generateForm.querySelector('input[name="regionQuestionTitle"]');
                        if (regionInput) {
                            var regionField = document.createElement('input');
                            regionField.type = 'hidden';
                            regionField.name = 'regionQuestionTitle';
                            regionField.value = regionInput.value;
                            postForm.appendChild(regionField);
                        }

                        document.body.appendChild(postForm);
                        postForm.submit();
                    });

                    generateForm.insertAdjacentElement('beforebegin', checkButton);
                });

                if (previewCard && !previewMoved) {
                    previewCard.classList.remove('estimation-preview-global');
                }
            });
        })();
    </script>
}

