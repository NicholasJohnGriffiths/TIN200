@page
@model TINWeb.Pages.CompanySurvey.EstimationModel
@{
    ViewData["Title"] = "Company Survey Estimation";
}

<style>
    .estimation-header {
        gap: 0.5rem;
    }

    .estimation-preview-card {
        border-top: 1px solid rgba(0, 0, 0, 0.08);
        background: #f8f9fa;
    }

    .estimation-preview-info {
        background-color: #e7f5ff;
        color: #084298;
    }

    .estimation-preview-used {
        background-color: #d1e7dd;
        color: #0f5132;
        font-weight: 600;
    }

    .estimation-applied-row > td {
        background-color: #d1e7dd !important;
        color: #0f5132;
        font-weight: 600;
    }

    .estimation-applied-badge {
        margin-left: 0.5rem;
    }

    .estimation-focus-card {
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.2);
        transition: box-shadow 0.6s ease;
    }

    .estimation-generate-btn {
        white-space: nowrap;
    }

    .estimation-check-btn {
        white-space: nowrap;
    }

    .estimation-manual-input {
        width: 160px;
        min-width: 120px;
    }

    .btn-label-short {
        display: none;
    }

    @@media (max-width: 768px) {
        .estimation-header {
            flex-wrap: wrap;
            align-items: flex-start !important;
        }

        .estimation-header span {
            flex: 1 1 100%;
            line-height: 1.25;
        }

        .estimation-header form {
            margin-left: 0;
        }

        .estimation-generate-btn {
            font-size: 0.75rem;
            padding: 0.2rem 0.5rem;
        }

        .estimation-check-btn {
            font-size: 0.75rem;
            padding: 0.2rem 0.5rem;
        }

        .estimation-manual-input {
            width: 120px;
        }

        .estimation-generate-btn .btn-label-full {
            display: none;
        }

        .estimation-generate-btn .btn-label-short {
            display: inline;
        }
    }
</style>

<div class="container mt-4" data-target-financial-year="@Model.TargetFinancialYear" data-company-survey-id="@Model.CompanySurveyId" data-check-metric-key="@Model.CheckMetricKey" data-check-has-value="@(Model.CheckSelectedValue.HasValue ? "true" : "false")" data-check-selected-value="@(Model.CheckSelectedValue.HasValue ? Model.CheckSelectedValue.Value.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) : string.Empty)" data-check-region-question-title="@Model.SelectedRegionalEmploymentQuestionTitle" data-applied-metric-key="@Model.AppliedMetricKey" data-applied-region-question-title="@Model.AppliedRegionQuestionTitle">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Company Survey Estimation</h1>
            <p class="text-muted mb-0">
                Company: <strong>@Model.CompanyName</strong> |
                Company Survey ID: <strong>@Model.CompanySurveyId</strong> |
                Target Financial Year: <strong>@Model.TargetFinancialYear</strong>
            </p>
        </div>
    </div>

    @if (Model.EstimationGroupSections.Any())
    {
        foreach (var groupSection in Model.EstimationGroupSections)
        {
            var groupTitle = string.IsNullOrWhiteSpace(groupSection.GroupTitle) ? "Ungrouped" : groupSection.GroupTitle;
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">@groupTitle</span>
                    <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#estimationGroup_@groupSection.GroupId" aria-expanded="false" aria-controls="estimationGroup_@groupSection.GroupId">Toggle</button>
                </div>
                <div id="estimationGroup_@groupSection.GroupId" class="collapse">
                    <div class="card-body">
                        @foreach (var gqQuestion in groupSection.Questions)
                        {
                            <div class="card mb-3">
                                <div class="card-header d-flex justify-content-between align-items-center estimation-header">
                                    <span>Last 5 Years - @gqQuestion.QuestionTitle</span>
                                    @if (Model.EstimateEnabled && !Model.IsLocked)
                                    {
                                        <form method="post" asp-page-handler="@gqQuestion.HandlerName" class="mb-0">
                                            <input type="hidden" name="companySurveyId" value="@Model.CompanySurveyId" />
                                            <input type="hidden" name="financialYear" value="@Model.FinancialYearFilter" />
                                            <input type="hidden" name="regionQuestionTitle" value="@gqQuestion.QuestionTitle" />
                                            <button type="submit" class="btn btn-sm btn-outline-success estimation-generate-btn"><span class="btn-label-full">Generate</span><span class="btn-label-short">Gen</span></button>
                                        </form>
                                    }
                                </div>
                                <div class="card-body p-0">
                                    @if (gqQuestion.LastFiveYears.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-striped mb-0">
                                                <thead class="table-dark">
                                                    <tr>
                                                        <th style="width: 200px;">Financial Year</th>
                                                        <th style="width: 220px;">Company Survey ID</th>
                                                        <th>@gqQuestion.ValueLabel</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var row in gqQuestion.LastFiveYears)
                                                    {
                                                        <tr>
                                                            <td>@row.FinancialYear</td>
                                                            <td>@row.CompanySurveyId</td>
                                                            <td>@(row.Value?.ToString("N2") ?? string.Empty)</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="p-3 text-muted">@gqQuestion.EmptyStateMessage</div>
                                    }
                                    @if (Model.GroupQuestionAppliedValues.TryGetValue(gqQuestion.QuestionTitle, out var gqApplied))
                                    {
                                        <div class="p-3">
                                            @{ Model.GroupQuestionAppliedReasons.TryGetValue(gqQuestion.QuestionTitle, out var gqReason); }
                                            <div class="alert alert-success mb-0">
                                                <strong>Generated Forecast:</strong> @gqApplied.ToString("N2")
                                                @if (!string.IsNullOrWhiteSpace(gqReason))
                                                {
                                                    <div class="small text-muted">@gqReason</div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }

    <div class="mb-3">
        <span class="badge @(Model.EstimateEnabled ? "bg-success" : "bg-secondary")">
            Estimate Flag: @(Model.EstimateEnabled ? "Enabled" : "Disabled")
        </span>
        <span class="badge @(Model.IsLocked ? "bg-danger" : "bg-success") ms-2">
            Locked: @(Model.IsLocked ? "Yes" : "No")
        </span>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (!string.IsNullOrWhiteSpace(Model.SaveMessage))
    {
        <div class="alert alert-success">@Model.SaveMessage</div>
    }

    @if (!Model.EstimateEnabled || Model.IsLocked)
    {
        <div class="alert alert-warning">
            <div><strong>Generate button unavailable</strong></div>
            @if (!Model.EstimateEnabled)
            {
                <div>- The Estimate flag is set to <strong>No</strong> on this Company Survey record.</div>
            }
            @if (Model.IsLocked)
            {
                <div>- This Company Survey record is currently <strong>Locked</strong>.</div>
            }
            <div class="mt-1">Enable Estimate and unlock the record on the edit page to generate estimates.</div>
        </div>
    }

    @if (Model.CheckCandidates.Any())
    {
        <div class="card mt-3 estimation-preview-card estimation-preview-global">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><strong>Check Preview:</strong> @Model.CheckMetricLabel</span>
                <span class="small text-muted">Actual -> Trend -> Fallback</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th style="width: 200px;">Calculation Step</th>
                                <th style="width: 220px;">Candidate Value</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var candidate in Model.CheckCandidates)
                            {
                                <tr class="@(candidate.IsUsed ? "estimation-preview-used" : "estimation-preview-info")">
                                    <td>
                                        @candidate.StepName
                                        @if (candidate.IsUsed)
                                        {
                                            <span class="badge bg-success ms-2">Used</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark ms-2">Info</span>
                                        }
                                    </td>
                                    <td>@(candidate.Value.HasValue ? candidate.Value.Value.ToString("N2") : "n/a")</td>
                                    <td>
                                        <div>@candidate.Details</div>
                                        @if (candidate.FailureReasons.Any())
                                        {
                                            <ul class="mb-0 mt-1 small">
                                                @foreach (var reason in candidate.FailureReasons)
                                                {
                                                    <li>@reason</li>
                                                }
                                            </ul>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <div class="mb-3">
        <a asp-page="./Index" asp-route-financialYear="@Model.FinancialYearFilter" class="btn btn-secondary">Back to Company Survey Records</a>
    </div>

