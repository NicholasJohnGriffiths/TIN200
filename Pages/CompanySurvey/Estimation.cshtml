        </div>
    }

    @if (Model.ForecastedResearchDevelopment.HasValue)
    {
        <div class="alert alert-success mt-3">
            <div><strong>Forecasted Research & Development:</strong> @Model.ForecastedResearchDevelopment.Value.ToString("N2")</div>
            <div class="small text-muted">@Model.ResearchDevelopmentForecastReason</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.ResearchDevelopmentForecastReason))
    {
        <div class="alert alert-warning mt-3">
            <div><strong>Forecasted Research & Development:</strong> not available</div>
            <div class="small text-muted">@Model.ResearchDevelopmentForecastReason</div>
        </div>
    }

    @if (Model.ForecastedSalesMarketing.HasValue)
    {
        <div class="alert alert-success mt-3">
            <div><strong>Forecasted Sales & Marketing:</strong> @Model.ForecastedSalesMarketing.Value.ToString("N2")</div>
            <div class="small text-muted">@Model.SalesMarketingForecastReason</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.SalesMarketingForecastReason))
    {
        <div class="alert alert-warning mt-3">
            <div><strong>Forecasted Sales & Marketing:</strong> not available</div>
            <div class="small text-muted">@Model.SalesMarketingForecastReason</div>
        </div>
    }

    @if (Model.ForecastedEbitda.HasValue)
    {
        <div class="alert alert-success mt-3">
            <div><strong>Forecasted EBITDA:</strong> @Model.ForecastedEbitda.Value.ToString("N2")</div>
            <div class="small text-muted">@Model.EbitdaForecastReason</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.EbitdaForecastReason))
    {
        <div class="alert alert-warning mt-3">
            <div><strong>Forecasted EBITDA:</strong> not available</div>
            <div class="small text-muted">@Model.EbitdaForecastReason</div>
        </div>
    }

    @if (Model.ForecastedRevenueNz.HasValue)
    {
        <div class="alert alert-success mt-3">
            <div><strong>Forecasted Revenue NZ:</strong> @Model.ForecastedRevenueNz.Value.ToString("N2")</div>
            <div class="small text-muted">@Model.RevenueNzForecastReason</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.RevenueNzForecastReason))
    {
        <div class="alert alert-warning mt-3">
            <div><strong>Forecasted Revenue NZ:</strong> not available</div>
            <div class="small text-muted">@Model.RevenueNzForecastReason</div>
        </div>
    }

    @if (Model.ForecastedRevenueAustralia.HasValue)
    {
        <div class="alert alert-success mt-3">
            <div><strong>Forecasted Revenue Australia:</strong> @Model.ForecastedRevenueAustralia.Value.ToString("N2")</div>
            <div class="small text-muted">@Model.RevenueAustraliaForecastReason</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.RevenueAustraliaForecastReason))
    {
        <div class="alert alert-warning mt-3">
            <div><strong>Forecasted Revenue Australia:</strong> not available</div>
            <div class="small text-muted">@Model.RevenueAustraliaForecastReason</div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.GeneratedSummary))
        @if (Model.ForecastedRevenueChina.HasValue) { <div class="alert alert-success mt-3"><div><strong>Forecasted Revenue China:</strong> @Model.ForecastedRevenueChina.Value.ToString("N2")</div><div class="small text-muted">@Model.RevenueChinaForecastReason</div></div> }
        else if (!string.IsNullOrWhiteSpace(Model.RevenueChinaForecastReason)) { <div class="alert alert-warning mt-3"><div><strong>Forecasted Revenue China:</strong> not available</div><div class="small text-muted">@Model.RevenueChinaForecastReason</div></div> }
        @if (Model.ForecastedRevenueRestOfAsia.HasValue) { <div class="alert alert-success mt-3"><div><strong>Forecasted Revenue Rest of Asia:</strong> @Model.ForecastedRevenueRestOfAsia.Value.ToString("N2")</div><div class="small text-muted">@Model.RevenueRestOfAsiaForecastReason</div></div> }
        else if (!string.IsNullOrWhiteSpace(Model.RevenueRestOfAsiaForecastReason)) { <div class="alert alert-warning mt-3"><div><strong>Forecasted Revenue Rest of Asia:</strong> not available</div><div class="small text-muted">@Model.RevenueRestOfAsiaForecastReason</div></div> }
        @if (Model.ForecastedRevenueNorthAmerica.HasValue) { <div class="alert alert-success mt-3"><div><strong>Forecasted Revenue North America:</strong> @Model.ForecastedRevenueNorthAmerica.Value.ToString("N2")</div><div class="small text-muted">@Model.RevenueNorthAmericaForecastReason</div></div> }
        else if (!string.IsNullOrWhiteSpace(Model.RevenueNorthAmericaForecastReason)) { <div class="alert alert-warning mt-3"><div><strong>Forecasted Revenue North America:</strong> not available</div><div class="small text-muted">@Model.RevenueNorthAmericaForecastReason</div></div> }
        @if (Model.ForecastedRevenueEurope.HasValue) { <div class="alert alert-success mt-3"><div><strong>Forecasted Revenue Europe:</strong> @Model.ForecastedRevenueEurope.Value.ToString("N2")</div><div class="small text-muted">@Model.RevenueEuropeForecastReason</div></div> }
        else if (!string.IsNullOrWhiteSpace(Model.RevenueEuropeForecastReason)) { <div class="alert alert-warning mt-3"><div><strong>Forecasted Revenue Europe:</strong> not available</div><div class="small text-muted">@Model.RevenueEuropeForecastReason</div></div> }
        @if (Model.ForecastedRevenueMiddleEast.HasValue) { <div class="alert alert-success mt-3"><div><strong>Forecasted Revenue Middle East:</strong> @Model.ForecastedRevenueMiddleEast.Value.ToString("N2")</div><div class="small text-muted">@Model.RevenueMiddleEastForecastReason</div></div> }
        else if (!string.IsNullOrWhiteSpace(Model.RevenueMiddleEastForecastReason)) { <div class="alert alert-warning mt-3"><div><strong>Forecasted Revenue Middle East:</strong> not available</div><div class="small text-muted">@Model.RevenueMiddleEastForecastReason</div></div> }
        @if (Model.ForecastedRevenueLatinAmerica.HasValue) { <div class="alert alert-success mt-3"><div><strong>Forecasted Revenue Latin America:</strong> @Model.ForecastedRevenueLatinAmerica.Value.ToString("N2")</div><div class="small text-muted">@Model.RevenueLatinAmericaForecastReason</div></div> }
        else if (!string.IsNullOrWhiteSpace(Model.RevenueLatinAmericaForecastReason)) { <div class="alert alert-warning mt-3"><div><strong>Forecasted Revenue Latin America:</strong> not available</div><div class="small text-muted">@Model.RevenueLatinAmericaForecastReason</div></div> }
        @if (Model.ForecastedRevenueAfrica.HasValue) { <div class="alert alert-success mt-3"><div><strong>Forecasted Revenue Africa:</strong> @Model.ForecastedRevenueAfrica.Value.ToString("N2")</div><div class="small text-muted">@Model.RevenueAfricaForecastReason</div></div> }
        else if (!string.IsNullOrWhiteSpace(Model.RevenueAfricaForecastReason)) { <div class="alert alert-warning mt-3"><div><strong>Forecasted Revenue Africa:</strong> not available</div><div class="small text-muted">@Model.RevenueAfricaForecastReason</div></div> }
        @if (Model.ForecastedRevenueOther.HasValue) { <div class="alert alert-success mt-3"><div><strong>Forecasted Revenue Other:</strong> @Model.ForecastedRevenueOther.Value.ToString("N2")</div><div class="small text-muted">@Model.RevenueOtherForecastReason</div></div> }
        else if (!string.IsNullOrWhiteSpace(Model.RevenueOtherForecastReason)) { <div class="alert alert-warning mt-3"><div><strong>Forecasted Revenue Other:</strong> not available</div><div class="small text-muted">@Model.RevenueOtherForecastReason</div></div> }

