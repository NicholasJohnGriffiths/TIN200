@page
@model TINWorkspaceTemp.Pages.CompanySurvey.IndexModel
@{
    ViewData["Title"] = "Company Survey Records";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Company Survey Records</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="./Create" class="btn btn-primary">Add New Record</a>
        </div>
    </div>

    @if (Model.Records.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Company Name</th>
                    <th>Saved</th>
                    <th>Submitted</th>
                    <th>Request</th>
                    <th>Answers</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model.Records)
                {
                    <tr>
                        <td>@record.CompanyName</td>
                        <td>@record.Saved</td>
                        <td>@record.Submitted</td>
                        <td>@record.Requested</td>
                        <td>
                            <a asp-page="/Answers/Index" asp-route-companySurveyId="@record.Id" class="btn btn-sm btn-primary">Open Answers</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No company survey records found.</div>
    }
</div>
