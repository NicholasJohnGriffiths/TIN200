@page
@model TINWeb.Pages.CompanySurvey.IndexModel
@{
    ViewData["Title"] = "Company Survey Records";
}

@functions {
    string SortHref(string column) => Url.Page(
        "/CompanySurvey/Index",
        null,
        new
        {
            financialYear = Model.SelectedFinancialYear,
            sortBy = column,
            sortDir = Model.GetNextSortDirection(column)
        },
        null) ?? "#";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Company Survey Records</h1>
            <p class="text-muted mb-0">Companies with answers: <strong>@Model.TotalCompaniesWithAnswers</strong> of <strong>@Model.Records.Count</strong></p>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <form method="get" class="d-flex">
                <label class="me-2 align-self-center">Survey Financial Year:</label>
                <select name="financialYear" class="form-select me-2" aria-label="Survey Financial Year" style="max-width: 180px;">
                    @foreach (var year in Model.FinancialYears)
                    {
                        <option value="@year" selected="@(Model.SelectedFinancialYear == year ? "selected" : null)">@year</option>
                    }
                </select>
                <button class="btn btn-outline-primary" type="submit">Apply</button>
            </form>
        </div>
    </div>

    @if (Model.Records.Any())
    {
        <table class="table table-striped table-hover company-table">
            <thead class="table-dark">
                <tr>
                    <th><a class="link-light text-decoration-none" href="@SortHref("CompanyName")"><span>Company Name</span><span>@Model.GetSortIndicator("CompanyName")</span></a></th>
                    <th><a class="link-light text-decoration-none" href="@SortHref("Saved")"><span>Saved</span><span>@Model.GetSortIndicator("Saved")</span></a></th>
                    <th><a class="link-light text-decoration-none" href="@SortHref("SavedDate")"><span>Saved Date</span><span>@Model.GetSortIndicator("SavedDate")</span></a></th>
                    <th><a class="link-light text-decoration-none" href="@SortHref("Submitted")"><span>Submitted</span><span>@Model.GetSortIndicator("Submitted")</span></a></th>
                    <th><a class="link-light text-decoration-none" href="@SortHref("SubmittedDate")"><span>Submitted Date</span><span>@Model.GetSortIndicator("SubmittedDate")</span></a></th>
                    <th><a class="link-light text-decoration-none" href="@SortHref("Requested")"><span>Requested</span><span>@Model.GetSortIndicator("Requested")</span></a></th>
                    <th><a class="link-light text-decoration-none" href="@SortHref("RequestedDate")"><span>Requested Date</span><span>@Model.GetSortIndicator("RequestedDate")</span></a></th>
                    <th><a class="link-light text-decoration-none" href="@SortHref("Locked")"><span>Locked</span><span>@Model.GetSortIndicator("Locked")</span></a></th>
                    <th><a class="link-light text-decoration-none" href="@SortHref("Estimate")"><span>Estimate</span><span>@Model.GetSortIndicator("Estimate")</span></a></th>
                    <th><a class="link-light text-decoration-none" href="@SortHref("AnswerCount")"><span>Answers</span><span>@Model.GetSortIndicator("AnswerCount")</span></a></th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model.Records)
                {
                    <tr id="record-@record.Id">
                        <td>@record.CompanyName</td>
                        <td>@(record.Saved ? "Yes" : "No")</td>
                        <td>@(record.SavedDate?.ToString("dd/MM/yyyy") ?? string.Empty)</td>
                        <td>@(record.Submitted ? "Yes" : "No")</td>
                        <td>@(record.SubmittedDate?.ToString("dd/MM/yyyy") ?? string.Empty)</td>
                        <td>@(record.Requested ? "Yes" : "No")</td>
                        <td>@(record.RequestedDate?.ToString("dd/MM/yyyy") ?? string.Empty)</td>
                        <td>@(record.Locked ? "Yes" : "No")</td>
                        <td>@(record.Estimate ? "Yes" : "No")</td>
                        <td>@record.AnswerCount</td>
                        <td class="actions-col text-nowrap">
                            <a asp-page="/CompanySurvey/Edit" asp-route-id="@record.Id" asp-route-financialYear="@Model.SelectedFinancialYear" class="btn btn-sm btn-secondary">Edit</a>
                            <a asp-page="/CompanySurvey/Estimation" asp-route-companySurveyId="@record.Id" asp-route-financialYear="@Model.SelectedFinancialYear" class="btn btn-sm btn-outline-success">Estimatation</a>
                            <a asp-page="/CompanySurvey/Notes" asp-route-companySurveyId="@record.Id" asp-route-financialYear="@Model.SelectedFinancialYear" class="btn btn-sm btn-outline-dark">Notes</a>
                            <a asp-page="/Answers/Index" asp-route-companySurveyId="@record.Id" asp-route-financialYear="@Model.SelectedFinancialYear" class="btn btn-sm btn-primary">Open Answers</a>
                            <a asp-page="/Company/SendSurvey"
                               asp-route-id="@record.CompanyId"
                               class="btn btn-sm btn-outline-primary send-survey-email-btn"
                               data-company-name="@record.CompanyName"
                               data-financial-year="@record.FinancialYear">Send Survey Link Email</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No company survey records found.</div>
    }
</div>

<script>
    (function () {
        const buttons = document.querySelectorAll('.send-survey-email-btn');
        if (!buttons.length) {
            return;
        }

        buttons.forEach(function (button) {
            button.addEventListener('click', function (event) {
                const companyName = button.getAttribute('data-company-name') || '';
                const financialYear = button.getAttribute('data-financial-year') || '';
                const message = `Do you want to continue?\n\nFinancial Year: ${financialYear}\nCompany: ${companyName}`;

                if (!window.confirm(message)) {
                    event.preventDefault();
                }
            });
        });
    })();
</script>
