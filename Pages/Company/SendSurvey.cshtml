@page
@model TINWeb.Pages.Company.SendSurveyModel
@{
    ViewData["Title"] = "Send Client Survey";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-10">
            <h1>Send Client Survey</h1>
            <p class="text-muted">Send a secure data update survey link to selected clients or all clients.</p>
            <hr />

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="alert alert-success" role="alert">
                    @Model.StatusMessage
                </div>
            }

            @if (Model.BulkSentCount.HasValue || Model.BulkSkippedCount.HasValue || Model.BulkFailedCount.HasValue)
            {
                <div class="card mb-3">
                    <div class="card-header">Last Bulk Send Summary</div>
                    <div class="card-body py-2">
                        @if (!string.IsNullOrWhiteSpace(Model.BulkLastRunAt))
                        {
                            <div><strong>Last run:</strong> @Model.BulkLastRunAt</div>
                        }
                        <div><strong>Sent:</strong> @(Model.BulkSentCount ?? 0)</div>
                        <div><strong>Skipped (no email):</strong> @(Model.BulkSkippedCount ?? 0)</div>
                        <div><strong>Failed:</strong> @(Model.BulkFailedCount ?? 0)</div>
                    </div>
                </div>
            }

            <div id="bulkSendProgressContainer" class="mb-3" style="display:none;">
                <div class="d-flex justify-content-between small mb-1">
                    <span id="bulkSendProgressLabel">Sending survey emails...</span>
                    <span id="bulkSendProgressPercent">0%</span>
                </div>
                <div class="progress" role="progressbar" aria-label="Bulk send progress" aria-valuemin="0" aria-valuemax="100">
                    <div id="bulkSendProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%"></div>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="card mb-3">
                <div class="card-header">Bulk Send</div>
                <div class="card-body">
                    <form id="bulkSendForm" method="post" asp-page-handler="Bulk">
                        <div class="form-check mb-3">
                            <input asp-for="SendToAllClients" class="form-check-input" />
                            <label asp-for="SendToAllClients" class="form-check-label">Send to all clients with an email address</label>
                        </div>

                        <div class="mb-2">
                            <button type="button" id="selectAllClientsBtn" class="btn btn-outline-secondary btn-sm">Select All Listed</button>
                            <button type="button" id="clearAllClientsBtn" class="btn btn-outline-secondary btn-sm">Clear Selection</button>
                        </div>

                        <div class="form-group mb-3">
                            <label for="clientSearchInput" class="form-label">Search clients</label>
                            <input id="clientSearchInput" class="form-control" type="text" placeholder="Search by ID, company, or email" />
                        </div>

                        <div class="mb-3" role="group" aria-label="Client email filters">
                            <button type="button" class="btn btn-outline-secondary btn-sm client-filter-btn active" data-filter="all">All</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm client-filter-btn" data-filter="has-email">Has Email Only</button>
                            <button type="button" class="btn btn-outline-secondary btn-sm client-filter-btn" data-filter="missing-email">Missing Email</button>
                        </div>

                        <div class="mb-3 d-flex align-items-center" role="group" aria-label="Survey email sent filter">
                            <label for="surveyEmailSentFilter" class="form-label me-2 mb-0">Survey Email Sent</label>
                            <select id="surveyEmailSentFilter" class="form-select form-select-sm" style="max-width: 180px;">
                                <option value="all">All</option>
                                <option value="sent">Sent</option>
                                <option value="not-sent">Not sent</option>
                            </select>
                        </div>

                        <div id="clientListContainer" class="table-responsive" style="max-height: 420px; overflow-y: auto;">
                            <table class="table table-striped align-middle company-table">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 80px;">Select</th>
                                        <th style="width: 80px;">
                                            <button type="button" class="btn btn-link p-0 sort-header" data-sort-key="id">ID</button>
                                        </th>
                                        <th>
                                            <button type="button" class="btn btn-link p-0 sort-header" data-sort-key="company">Company</button>
                                        </th>
                                        <th>
                                            <button type="button" class="btn btn-link p-0 sort-header" data-sort-key="email">Email</button>
                                        </th>
                                        <th style="width: 120px;">Survey Locked</th>
                                        <th style="width: 140px;">Survey Email Sent</th>
                                        <th style="width: 170px;">Survey Email Sent Last Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var clientRow in Model.AvailableClients)
                                    {
                                        var hasEmail = !string.IsNullOrWhiteSpace(clientRow.Email);
                                        var canSend = hasEmail && !clientRow.IsLocked;
                                        var disableReason = clientRow.IsLocked
                                            ? "Survey record is locked. Contact the Technology Investment Network."
                                            : "Cannot send survey email because no email address is available.";
                                        var searchText = $"{clientRow.Id} {clientRow.CompanyName} {clientRow.Email}".ToLowerInvariant();
                                        var companySort = (clientRow.CompanyName ?? string.Empty).ToLowerInvariant();
                                        var emailSort = (clientRow.Email ?? string.Empty).ToLowerInvariant();
                                        <tr class="@(Model.SelectedClientIds.Contains(clientRow.Id) ? "preselected-client-row" : string.Empty)" data-search="@searchText" data-has-email="@(hasEmail ? "true" : "false")" data-id="@clientRow.Id" data-company="@companySort" data-email="@emailSort" data-survey-email-sent="@(clientRow.SurveyEmailSent ? "true" : "false")">
                                            <td>
                                                @if (canSend)
                                                {
                                                    <input class="form-check-input client-selector" type="checkbox" name="SelectedClientIds" value="@clientRow.Id" checked="@Model.SelectedClientIds.Contains(clientRow.Id)" />
                                                }
                                                else
                                                {
                                                    <span title="@disableReason">
                                                        <input class="form-check-input client-selector" type="checkbox" name="SelectedClientIds" value="@clientRow.Id" disabled />
                                                    </span>
                                                    <span class="small text-muted ms-1" title="@disableReason">N/A</span>
                                                }
                                            </td>
                                            <td>@clientRow.Id</td>
                                            <td>@clientRow.CompanyName</td>
                                            <td>
                                                @if (hasEmail)
                                                {
                                                    @clientRow.Email
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No email</span>
                                                }
                                            </td>
                                            <td>
                                                @if (clientRow.IsLocked)
                                                {
                                                    <span class="badge bg-warning text-dark">Yes</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No</span>
                                                }
                                            </td>
                                            <td>@(clientRow.SurveyEmailSent ? "Yes" : "No")</td>
                                            <td>@(clientRow.SurveyEmailSentLastDate?.ToString("dd/MM/yyyy") ?? string.Empty)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <button type="submit" class="btn btn-primary mt-3">Send Survey Emails</button>
                    </form>
                </div>
            </div>

            <a asp-page="./Index" class="btn btn-secondary">Back to Records</a>
        </div>
    </div>
</div>

<div class="modal fade" id="bulkSendWarningModal" tabindex="-1" aria-labelledby="bulkSendWarningModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bulkSendWarningModalLabel">Confirm Bulk Email Send</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning mb-0" role="alert">
                    You are about to send survey emails to <strong id="bulkSendWarningTarget">selected clients</strong>. Please confirm to continue.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmBulkSendBtn" class="btn btn-danger">Send Emails</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            const selectAllBtn = document.getElementById('selectAllClientsBtn');
            const clearAllBtn = document.getElementById('clearAllClientsBtn');
            const sendToAllToggle = document.getElementById('SendToAllClients');
            const searchInput = document.getElementById('clientSearchInput');
            const surveyEmailSentFilterSelect = document.getElementById('surveyEmailSentFilter');
            const filterButtons = Array.from(document.querySelectorAll('.client-filter-btn'));
            const sortButtons = Array.from(document.querySelectorAll('.sort-header'));
            const selectableCheckboxes = Array.from(document.querySelectorAll('.client-selector:not([disabled])'));
            const tbody = document.querySelector('tbody');
            const clientListContainer = document.getElementById('clientListContainer');
            const bulkSendForm = document.getElementById('bulkSendForm');
            const warningModalElement = document.getElementById('bulkSendWarningModal');
            const warningTarget = document.getElementById('bulkSendWarningTarget');
            const confirmBulkSendBtn = document.getElementById('confirmBulkSendBtn');
            const bulkSendProgressContainer = document.getElementById('bulkSendProgressContainer');
            const bulkSendProgressBar = document.getElementById('bulkSendProgressBar');
            const bulkSendProgressPercent = document.getElementById('bulkSendProgressPercent');
            const bulkSendProgressLabel = document.getElementById('bulkSendProgressLabel');
            const warningModal = warningModalElement && window.bootstrap && window.bootstrap.Modal
                ? new window.bootstrap.Modal(warningModalElement)
                : null;
            const url = new URL(window.location.href);
            const storageKey = 'tin200_send_survey_selected_clients';
            const clearSavedSelectionsAfterSend = @Model.BulkSendSucceeded.ToString().ToLowerInvariant();
            const hasQueryPreselection = @Model.HasQueryPreselection.ToString().ToLowerInvariant();
            let bulkSendConfirmed = false;
            let searchParam = null;
            let filterParam = null;
            let activeFilter = 'all';
            let surveyEmailSentFilterParam = null;
            let activeSurveyEmailSentFilter = 'all';
            let sortKey = 'company';
            let sortDir = 'asc';
            let bulkProgressTimerId = null;

            if (!selectAllBtn || !clearAllBtn) {
                return;
            }

            if (clearSavedSelectionsAfterSend) {
                localStorage.removeItem(storageKey);
                url.searchParams.delete('search');
                url.searchParams.delete('filter');
                window.history.replaceState({}, '', url.toString());
            }

            searchParam = url.searchParams.get('search');
            filterParam = url.searchParams.get('filter');
            surveyEmailSentFilterParam = url.searchParams.get('surveyEmailSentFilter');

            const sortParam = (url.searchParams.get('sort') || '').toLowerCase();
            const sortDirParam = (url.searchParams.get('dir') || '').toLowerCase();
            if (['id', 'company', 'email'].includes(sortParam)) {
                sortKey = sortParam;
            }
            if (['asc', 'desc'].includes(sortDirParam)) {
                sortDir = sortDirParam;
            }

            const getCheckboxes = () => Array.from(document.querySelectorAll('.client-selector:not([disabled])'));
            const getVisibleRows = () => Array.from(document.querySelectorAll('tbody tr')).filter(row => row.style.display !== 'none');
            const getSearchRows = () => Array.from(document.querySelectorAll('tbody tr[data-search]'));

            const saveSelections = () => {
                const selectedIds = getCheckboxes()
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);
                localStorage.setItem(storageKey, JSON.stringify(selectedIds));
            };

            const restoreSelections = () => {
                const raw = localStorage.getItem(storageKey);
                if (!raw) {
                    return;
                }

                let selectedIds;
                try {
                    selectedIds = JSON.parse(raw);
                } catch {
                    return;
                }

                if (!Array.isArray(selectedIds)) {
                    return;
                }

                const selectedSet = new Set(selectedIds.map(String));
                getCheckboxes().forEach(function (cb) {
                    cb.checked = selectedSet.has(String(cb.value));
                });
            };

            const revealPreselectedClient = () => {
                if (!hasQueryPreselection) {
                    return;
                }

                const selectedCheckbox = document.querySelector('tbody .client-selector:checked');
                if (!selectedCheckbox) {
                    return;
                }

                const selectedRow = selectedCheckbox.closest('tr');
                if (!selectedRow || selectedRow.style.display === 'none') {
                    return;
                }

                selectedRow.classList.add('table-warning');

                if (clientListContainer) {
                    const rowTop = selectedRow.offsetTop;
                    const rowHeight = selectedRow.offsetHeight;
                    const containerHeight = clientListContainer.clientHeight;
                    const targetTop = Math.max(0, rowTop - (containerHeight / 2) + (rowHeight / 2));
                    clientListContainer.scrollTop = targetTop;
                    return;
                }

                selectedRow.scrollIntoView({ behavior: 'auto', block: 'center' });
            };

            const syncUrlState = () => {
                const term = ((searchInput && searchInput.value) || '').trim();

                if (term) {
                    url.searchParams.set('search', term);
                } else {
                    url.searchParams.delete('search');
                }

                if (activeFilter && activeFilter !== 'all') {
                    url.searchParams.set('filter', activeFilter);
                } else {
                    url.searchParams.delete('filter');
                }

                if (activeSurveyEmailSentFilter && activeSurveyEmailSentFilter !== 'all') {
                    url.searchParams.set('surveyEmailSentFilter', activeSurveyEmailSentFilter);
                } else {
                    url.searchParams.delete('surveyEmailSentFilter');
                }

                if (sortKey !== 'company') {
                    url.searchParams.set('sort', sortKey);
                } else {
                    url.searchParams.delete('sort');
                }

                if (sortDir !== 'asc') {
                    url.searchParams.set('dir', sortDir);
                } else {
                    url.searchParams.delete('dir');
                }

                window.history.replaceState({}, '', url.toString());
            };

            const setSortButtonText = () => {
                sortButtons.forEach(function (btn) {
                    const key = btn.getAttribute('data-sort-key');
                    const baseLabel = (key || '').charAt(0).toUpperCase() + (key || '').slice(1);
                    if (key === sortKey) {
                        btn.textContent = `${baseLabel} ${sortDir === 'asc' ? '↑' : '↓'}`;
                    } else {
                        btn.textContent = baseLabel;
                    }
                });
            };

            const startBulkSendProgress = () => {
                if (!bulkSendProgressContainer || !bulkSendProgressBar || !bulkSendProgressPercent || !bulkSendProgressLabel) {
                    return;
                }

                if (bulkProgressTimerId) {
                    window.clearInterval(bulkProgressTimerId);
                }

                let value = 10;
                bulkSendProgressLabel.textContent = 'Sending survey emails...';
                bulkSendProgressContainer.style.display = '';

                const render = () => {
                    bulkSendProgressBar.style.width = `${value}%`;
                    bulkSendProgressPercent.textContent = `${value}%`;
                };

                render();

                bulkProgressTimerId = window.setInterval(() => {
                    if (value < 92) {
                        value += 4;
                        render();
                    }
                }, 300);
            };

            const applySort = () => {
                if (!tbody) {
                    return;
                }

                const rows = Array.from(tbody.querySelectorAll('tr[data-search]'));
                rows.sort(function (a, b) {
                    let aVal;
                    let bVal;

                    if (sortKey === 'id') {
                        aVal = parseInt(a.getAttribute('data-id') || '0', 10);
                        bVal = parseInt(b.getAttribute('data-id') || '0', 10);
                    } else if (sortKey === 'email') {
                        aVal = a.getAttribute('data-email') || '';
                        bVal = b.getAttribute('data-email') || '';
                    } else {
                        aVal = a.getAttribute('data-company') || '';
                        bVal = b.getAttribute('data-company') || '';
                    }

                    if (aVal < bVal) {
                        return sortDir === 'asc' ? -1 : 1;
                    }
                    if (aVal > bVal) {
                        return sortDir === 'asc' ? 1 : -1;
                    }
                    return 0;
                });

                rows.forEach(function (row) {
                    tbody.appendChild(row);
                });

                setSortButtonText();
                syncUrlState();
            };

            const setActiveFilterButton = () => {
                filterButtons.forEach(function (btn) {
                    const btnFilter = btn.getAttribute('data-filter') || 'all';
                    btn.classList.toggle('active', btnFilter === activeFilter);
                });
            };

            const applyFilters = () => {
                const term = ((searchInput && searchInput.value) || '').toLowerCase().trim();
                const rows = getSearchRows();

                rows.forEach(function (row) {
                    const haystack = row.getAttribute('data-search') || '';
                    const hasEmail = (row.getAttribute('data-has-email') || 'false') === 'true';
                    const surveyEmailSent = (row.getAttribute('data-survey-email-sent') || 'false') === 'true';

                    const matchesSearch = !term || haystack.includes(term);
                    const matchesEmailFilter =
                        activeFilter === 'all' ||
                        (activeFilter === 'has-email' && hasEmail) ||
                        (activeFilter === 'missing-email' && !hasEmail);
                    const matchesSurveyEmailSentFilter =
                        activeSurveyEmailSentFilter === 'all' ||
                        (activeSurveyEmailSentFilter === 'sent' && surveyEmailSent) ||
                        (activeSurveyEmailSentFilter === 'not-sent' && !surveyEmailSent);

                    row.style.display = matchesSearch && matchesEmailFilter && matchesSurveyEmailSentFilter ? '' : 'none';
                });

                syncUrlState();
            };

            if (searchInput && searchParam) {
                searchInput.value = searchParam;
            }

            if (filterParam && ['all', 'has-email', 'missing-email'].includes(filterParam)) {
                activeFilter = filterParam;
            }

            if (surveyEmailSentFilterParam && ['all', 'sent', 'not-sent'].includes(surveyEmailSentFilterParam)) {
                activeSurveyEmailSentFilter = surveyEmailSentFilterParam;
            }

            if (surveyEmailSentFilterSelect) {
                surveyEmailSentFilterSelect.value = activeSurveyEmailSentFilter;
            }

            setActiveFilterButton();

            setSortButtonText();

            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    applyFilters();
                });
            }

            filterButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    activeFilter = button.getAttribute('data-filter') || 'all';
                    setActiveFilterButton();
                    applyFilters();
                });
            });

            if (surveyEmailSentFilterSelect) {
                surveyEmailSentFilterSelect.addEventListener('change', function () {
                    activeSurveyEmailSentFilter = surveyEmailSentFilterSelect.value || 'all';
                    applyFilters();
                });
            }

            sortButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    const clickedKey = button.getAttribute('data-sort-key') || 'company';
                    if (sortKey === clickedKey) {
                        sortDir = sortDir === 'asc' ? 'desc' : 'asc';
                    } else {
                        sortKey = clickedKey;
                        sortDir = 'asc';
                    }
                    applySort();
                });
            });

            applySort();

            applyFilters();

            if (hasQueryPreselection) {
                saveSelections();
            } else {
                restoreSelections();
            }

            revealPreselectedClient();

            selectAllBtn.addEventListener('click', function () {
                getVisibleRows().forEach(function (row) {
                    const checkbox = row.querySelector('.client-selector:not([disabled])');
                    if (checkbox) {
                        checkbox.checked = true;
                    }
                });
                saveSelections();
            });

            clearAllBtn.addEventListener('click', function () {
                getCheckboxes().forEach(cb => cb.checked = false);
                if (sendToAllToggle) {
                    sendToAllToggle.checked = false;
                }
                saveSelections();
            });

            if (sendToAllToggle) {
                const applySendToAllSelection = () => {
                    getCheckboxes().forEach(function (cb) {
                        cb.checked = sendToAllToggle.checked;
                    });
                    saveSelections();
                };

                sendToAllToggle.addEventListener('change', applySendToAllSelection);

                if (sendToAllToggle.checked) {
                    applySendToAllSelection();
                }
            }

            selectableCheckboxes.forEach(function (checkbox) {
                checkbox.addEventListener('change', function () {
                    saveSelections();
                });
            });

            if (bulkSendForm) {
                bulkSendForm.addEventListener('submit', function (event) {
                    if (bulkSendConfirmed) {
                        startBulkSendProgress();
                        return;
                    }

                    const selectedCount = getCheckboxes().filter(cb => cb.checked).length;
                    const recipientCount = sendToAllToggle && sendToAllToggle.checked
                        ? getCheckboxes().length
                        : selectedCount;
                    const selectedMessage = sendToAllToggle && sendToAllToggle.checked
                        ? 'all clients with an email address'
                        : `${selectedCount} selected client${selectedCount === 1 ? '' : 's'}`;

                    event.preventDefault();

                    if (warningTarget) {
                        warningTarget.textContent = selectedMessage;
                    }

                    if (confirmBulkSendBtn) {
                        confirmBulkSendBtn.textContent = `Send to ${recipientCount} Client${recipientCount === 1 ? '' : 's'}`;
                    }

                    if (warningModal) {
                        warningModal.show();
                        return;
                    }

                    const confirmed = window.confirm(`Warning: You are about to send survey emails to ${selectedMessage}. Do you want to continue?`);
                    if (!confirmed) {
                        return;
                    }

                    bulkSendConfirmed = true;
                    startBulkSendProgress();
                    bulkSendForm.submit();
                });
            }

            if (confirmBulkSendBtn && bulkSendForm) {
                confirmBulkSendBtn.addEventListener('click', function () {
                    bulkSendConfirmed = true;
                    startBulkSendProgress();
                    if (warningModal) {
                        warningModal.hide();
                    }
                    bulkSendForm.submit();
                });
            }
        })();
    </script>
}

