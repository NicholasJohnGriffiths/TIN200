@page
@model TINWeb.Pages.Company.ImportModel
@{
    ViewData["Title"] = "Import Companies";
}

<h2>Import Companies</h2>

<div class="mb-3">
    <label for="UploadFile" class="form-label">Tab-delimited file</label>
    <input class="form-control" type="file" id="UploadFile" name="UploadFile" />
    <div class="mt-2">
        <button id="btnPreview" class="btn btn-secondary">Preview</button>
        <button id="btnConfirm" class="btn btn-primary" disabled>Confirm Import</button>
    </div>
    <div class="progress mt-3" style="height:20px; display:none;" id="uploadProgress">
        <div id="uploadBar" class="progress-bar" role="progressbar" style="width:0%">0%</div>
    </div>
    <div id="messages" class="mt-3"></div>
    <div id="previewContainer" class="mt-3"></div>
    <div id="errorsContainer" class="mt-3"></div>
</div>

<script>
    (function () {
        const uploadInput = document.getElementById('UploadFile');
        const btnPreview = document.getElementById('btnPreview');
        const btnConfirm = document.getElementById('btnConfirm');
        const progress = document.getElementById('uploadProgress');
        const bar = document.getElementById('uploadBar');
        const messages = document.getElementById('messages');
        const previewContainer = document.getElementById('previewContainer');
        const errorsContainer = document.getElementById('errorsContainer');

        function showMessage(html, type = 'info') {
            messages.innerHTML = `<div class="alert alert-${type}">${html}</div>`;
        }

        function clearMessages() {
            messages.innerHTML = '';
        }

        function buildPreviewTable(rows) {
            if (!rows || rows.length === 0) return '<div>No preview rows.</div>';
            let html = '<div class="table-responsive"><table class="table table-sm table-striped"><thead><tr>' +
                '<th>#</th><th>CEO First</th><th>CEO Last</th><th>Email</th><th>External ID</th><th>Company</th><th>FYE 2025</th><th>FYE 2024</th><th>FYE 2023</th></tr></thead><tbody>';
            rows.forEach(r => {
                const extCell = r.externalId ? r.externalId : '<span class="text-danger">MISSING</span>';
                html += `<tr><td>${r.row}</td><td>${r.ceoFirst ?? ''}</td><td>${r.ceoLast ?? ''}</td><td>${r.email ?? ''}</td><td>${extCell}</td><td>${r.companyName ?? ''}</td><td>${r.fye2025 ?? ''}</td><td>${r.fye2024 ?? ''}</td><td>${r.fye2023 ?? ''}</td></tr>`;
            });
            html += '</tbody></table></div>';
            return html;
        }

        btnPreview.addEventListener('click', function (e) {
            e.preventDefault();
            clearMessages(); previewContainer.innerHTML = ''; errorsContainer.innerHTML = '';
            const file = uploadInput.files[0];
            if (!file) return showMessage('Please choose a file first.', 'warning');

            const form = new FormData();
            form.append('UploadFile', file);

            const xhr = new XMLHttpRequest();
            xhr.open('POST', '?handler=Preview');
            xhr.upload.addEventListener('progress', function (ev) {
                if (ev.lengthComputable) {
                    const pct = Math.round(ev.loaded / ev.total * 100);
                    progress.style.display = 'block';
                    bar.style.width = pct + '%';
                    bar.textContent = pct + '%';
                }
            });
            xhr.onreadystatechange = function () {
                if (xhr.readyState === 4) {
                    progress.style.display = 'none';
                    bar.style.width = '0%';
                    bar.textContent = '0%';
                    if (xhr.status === 200) {
                        const json = JSON.parse(xhr.responseText);
                        if (!json.success) {
                            showMessage(json.message || 'Preview failed', 'danger');
                            return;
                        }
                        if (json.errors && json.errors.length) {
                            errorsContainer.innerHTML = '<div class="alert alert-warning"><ul>' + json.errors.map(e => `<li>${e}</li>`).join('') + '</ul></div>';
                        }
                        previewContainer.innerHTML = buildPreviewTable(json.preview);
                        btnConfirm.disabled = false;
                        const total = json.total || (json.preview ? json.preview.length : 0);
                        showMessage(`Preview loaded — ${total} rows. Review and press Confirm to insert.`, 'info');
                    } else {
                        showMessage('Server error during preview.', 'danger');
                    }
                }
            };
            xhr.send(form);
        });

        btnConfirm.addEventListener('click', function (e) {
            e.preventDefault();
            clearMessages();
            const file = uploadInput.files[0];
            if (!file) return showMessage('Please choose a file first.', 'warning');
            if (!confirm('Are you sure you want to import the file? This will insert rows into the database.') ) return;

            const form = new FormData();
            form.append('UploadFile', file);

            const xhr = new XMLHttpRequest();
            xhr.open('POST', '?handler=Confirm');
            xhr.upload.addEventListener('progress', function (ev) {
                if (ev.lengthComputable) {
                    const pct = Math.round(ev.loaded / ev.total * 100);
                    progress.style.display = 'block';
                    bar.style.width = pct + '%';
                    bar.textContent = pct + '%';
                }
            });
            xhr.onreadystatechange = function () {
                if (xhr.readyState === 4) {
                    progress.style.display = 'none';
                    bar.style.width = '0%';
                    bar.textContent = '0%';
                    if (xhr.status === 200) {
                        const json = JSON.parse(xhr.responseText);
                        if (!json.success) {
                            showMessage(json.message || 'Import failed', 'danger');
                            if (json.errors && json.errors.length) errorsContainer.innerHTML = '<div class="alert alert-warning"><ul>' + json.errors.map(e => `<li>${e}</li>`).join('') + '</ul></div>';
                            return;
                        }
                        const inserted = json.inserted || 0;
                        const updated = json.updated || 0;
                        const total = json.total || (inserted + updated);
                        showMessage(`Import complete — inserted ${inserted}, updated ${updated} (total ${total}).`, 'success');
                        errorsContainer.innerHTML = '';
                        previewContainer.innerHTML = '';
                        btnConfirm.disabled = true;
                    } else {
                        showMessage('Server error during import.', 'danger');
                    }
                }
            };
            xhr.send(form);
        });
    })();
</script>

