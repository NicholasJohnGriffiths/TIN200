@page "{id}"
@model TINWeb.Pages.Company.DeleteModel
@{
    ViewData["Title"] = "Delete Company";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <h1>Delete Company</h1>
            <hr />

            @if (Model.Record != null)
            {
                <div class="alert alert-danger" role="alert">
                    <strong>Warning!</strong> Deleting this company will permanently remove the company record and all related survey and answer data. This action cannot be undone.
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">@Model.Record.CompanyName</h5>
                        <p class="card-text">
                            <strong>CEO:</strong> @Model.Record.CeoFirstName @Model.Record.CeoLastName<br />
                            <strong>Email:</strong> @Model.Record.Email
                        </p>
                    </div>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Record.Id" />
                    <div class="mb-3">
                        <label for="deleteConfirm" class="form-label">Type <strong>delete</strong> to confirm:</label>
                        <input type="text" id="deleteConfirm" class="form-control" autocomplete="off" />
                    </div>
                    <button type="submit" id="deleteBtn" class="btn btn-danger me-2" disabled>Confirm Delete</button>
                    <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
                </form>
                <script>
                    (function () {
                        var input = document.getElementById('deleteConfirm');
                        var btn = document.getElementById('deleteBtn');
                        input.addEventListener('input', function () {
                            btn.disabled = input.value.trim().toLowerCase() !== 'delete';
                        });
                    })();
                </script>
            }
            else
            {
                <div class="alert alert-danger" role="alert">
                    Record not found.
                </div>
            }
        </div>
    </div>
</div>

