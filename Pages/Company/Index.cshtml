@page
@model TINWeb.Pages.Company.IndexModel
@{
    ViewData["Title"] = "Companies";
}

<div class="container-fluid px-0 mt-3">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info" role="alert">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    @if (Model.PreviewSummary != null)
    {
        if (!Model.PreviewSummary.HasCurrentSurvey)
        {
            <div class="alert alert-warning" role="alert">
                No current survey is configured, so no preview is available.
            </div>
        }
        else
        {
            <div class="card mb-3 border-warning">
                <div class="card-header bg-warning-subtle">
                    Update Company Info Preview (Current survey year: @Model.PreviewSummary.CurrentSurveyYear)
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-2">FYE values use current survey first, then roll back by year (e.g., Year-1 can fall back to prior survey Last Financial Year; Year-2 can fall back to prior survey Year-1). CEO fields use latest available non-blank survey answers.</p>
                    <p class="mb-2">
                        Matched companies: <strong>@Model.PreviewSummary.TotalMatchedCompanies</strong>
                        &mdash; with revenue answer data: <strong>@Model.PreviewSummary.CompaniesWithRevenueData</strong>,
                        with CEO answer data: <strong>@Model.PreviewSummary.CompaniesWithCeoData</strong>.<br />
                        Companies that would be updated: <strong>@Model.PreviewSummary.WouldUpdateCompanyCount</strong>.
                        @if (Model.PreviewSummary.WouldUpdateCompanyCount == 0 && Model.PreviewSummary.TotalMatchedCompanies > 0)
                        {
                            <br /><span class="text-muted small">No changes detected &mdash; answer data matches existing company values, or no answer data is available for those fields yet.</span>
                        }
                    </p>
                    @if (Model.PreviewSummary.PreviewRows.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Company</th>
                                        <th>CEO First Name</th>
                                        <th>CEO Last Name</th>
                                        <th>Email</th>
                                        <th>FYE Last Financial Year</th>
                                        <th>FYE Year-1</th>
                                        <th>FYE Year-2</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in Model.PreviewSummary.PreviewRows)
                                    {
                                        <tr>
                                            <td>@row.CompanyName (@row.CompanyId)</td>
                                            <td>@(row.NewCeoFirstName != null && row.CurrentCeoFirstName != row.NewCeoFirstName ? $"{row.CurrentCeoFirstName} -> {row.NewCeoFirstName}" : row.CurrentCeoFirstName ?? "")</td>
                                            <td>@(row.NewCeoLastName != null && row.CurrentCeoLastName != row.NewCeoLastName ? $"{row.CurrentCeoLastName} -> {row.NewCeoLastName}" : row.CurrentCeoLastName ?? "")</td>
                                            <td>@(row.NewEmail != null && row.CurrentEmail != row.NewEmail ? $"{row.CurrentEmail} -> {row.NewEmail}" : row.CurrentEmail ?? "")</td>
                                            <td>@(row.CurrentFye2025?.ToString("C0") ?? "") -> @(row.NewFye2025?.ToString("C0") ?? "")</td>
                                            <td>@(row.CurrentFye2024?.ToString("C0") ?? "") -> @(row.NewFye2024?.ToString("C0") ?? "")</td>
                                            <td>@(row.CurrentFye2023?.ToString("C0") ?? "") -> @(row.NewFye2023?.ToString("C0") ?? "")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <p class="small text-muted mt-2 mb-0">Showing up to @Model.PreviewSummary.PreviewRows.Count company change row(s).</p>
                    }
                </div>
            </div>
        }
    }

    @if (Model.GlobalImportPreview != null)
    {
        <div class="card mb-3 border-dark">
            <div class="card-body">
                <h5 class="card-title mb-3">Global Company Import Summary</h5>
                <p class="mb-1"><strong>Import Year for new companies:</strong> @Model.GlobalImportPreview.ImportYear</p>
                <p class="mb-1"><strong>Existing records to update:</strong> @Model.GlobalImportPreview.UpdatedCount</p>
                <p class="mb-1"><strong>New records to add:</strong> @Model.GlobalImportPreview.InsertedCount</p>
                <p class="mb-1"><strong>Unchanged records:</strong> @Model.GlobalImportPreview.UnchangedCount</p>
                <p class="mb-3"><strong>Estimated CompanySurvey records to add:</strong> @Model.GlobalImportPreview.EstimatedCompanySurveyCreatedCount</p>
                @if (Model.GlobalImportPreview.InsertedCount == 0
                    && Model.GlobalImportPreview.UpdatedCount == 0
                    && Model.GlobalImportPreview.EstimatedCompanySurveyCreatedCount > 0)
                {
                    <div class="alert alert-warning py-2" role="alert">
                        No company rows will be added or updated, but applying this import is still expected to create @Model.GlobalImportPreview.EstimatedCompanySurveyCreatedCount CompanySurvey record(s) for the selected import year.
                    </div>
                }
                <p class="mb-3 text-muted">Matching used: Excel <strong>External ID</strong> to Company <strong>ExternalId</strong>, then fallback Excel <strong>Company Name</strong> to Company <strong>CompanyName</strong> when the External ID does not match an existing company.</p>

                <p class="mb-1"><strong>Matched columns:</strong></p>
                @if (Model.GlobalImportPreview.MatchedHeaders.Any())
                {
                    <div class="small text-success mb-3">@string.Join(", ", Model.GlobalImportPreview.MatchedHeaders)</div>
                }
                else
                {
                    <div class="small text-muted mb-3">(none)</div>
                }

                <p class="mb-1"><strong>Unmatched columns:</strong></p>
                @if (Model.GlobalImportPreview.UnmatchedHeaders.Any())
                {
                    <div class="small text-muted mb-3">@string.Join(", ", Model.GlobalImportPreview.UnmatchedHeaders)</div>
                }
                else
                {
                    <div class="small text-muted mb-3">(none)</div>
                }

                @if (Model.GlobalImportPreview.MatchedFields.Any())
                {
                    <p class="mb-1"><strong>Matched company fields:</strong></p>
                    <ul class="small text-muted mb-3">
                        @foreach (var matchedField in Model.GlobalImportPreview.MatchedFields)
                        {
                            <li>@matchedField</li>
                        }
                    </ul>
                }

                @if (Model.GlobalImportPreview.Errors.Any())
                {
                    <p class="mb-1 text-danger"><strong>Preview warnings:</strong></p>
                    <ul class="small text-danger mb-3">
                        @foreach (var error in Model.GlobalImportPreview.Errors.Take(20))
                        {
                            <li>@error</li>
                        }
                    </ul>
                }

                @if (Model.GlobalImportPreview.PreviewRows.Any())
                {
                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-bordered align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Row</th>
                                    <th>Action</th>
                                    <th>Existing Record</th>
                                    <th>Imported External ID</th>
                                    <th>Imported Company Name</th>
                                    <th>Imported Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.GlobalImportPreview.PreviewRows)
                                {
                                    <tr>
                                        <td>@row.RowNumber</td>
                                        <td>@row.Action</td>
                                        <td>
                                            @if (row.ExistingCompanyId.HasValue)
                                            {
                                                <span>#@row.ExistingCompanyId</span>
                                                <span> | @row.ExistingCompanyName</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">New record</span>
                                            }
                                        </td>
                                        <td>@(row.ImportedExternalId ?? "")</td>
                                        <td>@(row.ImportedCompanyName ?? "")</td>
                                        <td>@(row.ImportedCompanyDescription ?? "")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <form method="post" asp-page-handler="ApplyGlobalImport" class="d-inline" id="applyGlobalImportForm">
                    <input type="hidden" name="previewToken" value="@Model.PendingGlobalImportToken" />
                    <button type="submit" class="btn btn-dark">Apply Global Import</button>
                </form>
            </div>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Companies (@Model.Records.Count)</h1>
        </div>
        <div class="col-md-4 text-end">
            <div class="d-inline-flex align-items-center gap-2 flex-wrap justify-content-end">
                <form method="post" asp-page-handler="PreviewGlobalImport" enctype="multipart/form-data" class="d-inline-flex align-items-center gap-2" id="globalImportForm">
                    <input type="hidden" name="lastTin200Year" value="@Model.SelectedLastTin200Year" />
                    <input type="number" name="importYear" value="@Model.SelectedImportYear" class="form-control form-control-sm" style="max-width: 120px;" placeholder="Import Year" min="1900" max="9999" />
                    <input type="file" name="importFile" accept=".xlsx" class="form-control form-control-sm" style="max-width: 220px;" />
                    <button type="submit" class="btn btn-outline-dark btn-sm">Import Global File</button>
                </form>
                <form method="post" asp-page-handler="PreviewResetFyeValues" class="d-inline">
                    <input type="hidden" name="lastTin200Year" value="@Model.SelectedLastTin200Year" />
                    <button type="submit" class="btn btn-outline-secondary me-2" id="companyResetPreviewButton">Preview Summary</button>
                </form>
                <form method="post" asp-page-handler="ResetFyeValues" class="d-inline" onsubmit="return confirm('Update company info (CEO name, email, FYE Last Financial Year / Year-1 / Year-2) from survey answers? This will overwrite existing values.');">
                    <input type="hidden" name="lastTin200Year" value="@Model.SelectedLastTin200Year" />
                    <button type="submit" class="btn btn-outline-warning me-2" id="companyResetButton">Update Company Info</button>
                </form>
                <a asp-page="./Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Add New Record
                </a>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <form method="get" class="d-flex" id="companyFilterForm">
                <label class="me-2 align-self-center">Filter Last TIN200 Year:</label>
                <select name="lastTin200Year" class="form-select me-2" aria-label="Last TIN200 Year">
                    <option value="">All</option>
                    @foreach (var y in Model.AvailableLastTin200Years)
                    {
                        <option value="@y" selected="@(Model.SelectedLastTin200Year == y ? "selected" : null)">@y</option>
                    }
                </select>
                <button class="btn btn-outline-primary" type="submit">Apply</button>
                <button class="btn btn-success ms-2" id="companyExportButton" type="submit" formaction="@Url.Page("./Export")">Export</button>
                <button class="btn btn-outline-success ms-2" id="companySmExportButton" type="submit" formaction="@Url.Page("./ExportSurveyMonkey")">SM Export</button>
                <a class="btn btn-link ms-2" href="@Url.Page("./Index")">Clear</a>
            </form>
        </div>
    </div>

    <div id="companyExportProgressContainer" class="mb-3" style="display:none;">
        <div class="d-flex justify-content-between small mb-1">
            <span id="companyExportProgressLabel">Exporting companies...</span>
            <span id="companyExportProgressPercent">0%</span>
        </div>
        <div class="progress" role="progressbar" aria-label="Company export progress" aria-valuemin="0" aria-valuemax="100">
            <div id="companyExportProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%"></div>
        </div>
    </div>

    @if (Model.Records.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover company-table">
                <thead class="table-dark">
                    <tr>
                        <th class="sortable" data-type="number">ID</th>
                        <th class="sortable" data-type="string">Company Name</th>
                        <th class="sortable" data-type="string">CEO Name</th>
                        <th class="sortable" data-type="string">Email</th>
                        <th class="sortable" data-type="string">External ID</th>
                        <th class="sortable" data-type="number">FYE Last Financial Year</th>
                        <th class="sortable" data-type="number">FYE Year-1</th>
                        <th class="sortable" data-type="number">FYE Year-2</th>
                        <th class="sortable" data-type="number">Financial Year</th>
                        <th class="sortable" data-type="number">Last TIN200 Year</th>
                        <th class="actions-header">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in Model.Records)
                    {
                        <tr id="company-row-@record.Id">
                            <td>@record.Id</td>
                            <td>@record.CompanyName</td>
                            <td>@record.CeoFirstName @record.CeoLastName</td>
                            <td>@record.Email</td>
                            <td>@record.ExternalId</td>
                            <td>@(record.Fye2025.HasValue ? record.Fye2025.Value.ToString("C0") : "")</td>
                            <td>@(record.Fye2024.HasValue ? record.Fye2024.Value.ToString("C0") : "")</td>
                            <td>@(record.Fye2023.HasValue ? record.Fye2023.Value.ToString("C0") : "")</td>
                            <td>@record.FinancialYear</td>
                            <td>@record.LastTIN200Year</td>
                            <td class="actions-col">
                                <a asp-page="./Details" asp-route-id="@record.Id" class="btn btn-sm btn-info">View</a>
                                <a asp-page="./Edit" asp-route-id="@record.Id" asp-route-lastTin200Year="@Model.SelectedLastTin200Year" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-page="./SurveyHistory" asp-route-id="@record.Id" class="btn btn-sm btn-outline-secondary">Survey History</a>
                                <a asp-page="./SendSurvey" asp-route-id="@record.Id" class="btn btn-sm btn-primary">Survey</a>
                                <a asp-page="./Delete" asp-route-id="@record.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <strong>No records found.</strong> <a asp-page="./Create">Create the first record</a>
        </div>
    }
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f5f5f5;
    }
</style>
<style>
    .sortable { cursor: pointer; }
    .sortable:after { content: '\25B4\25BE'; font-size: 0.6rem; color: #ddd; padding-left: 6px; }
    .sortable.sorted-asc:after { content: '\25B4'; color: #444; }
    .sortable.sorted-desc:after { content: '\25BE'; color: #444; }
</style>

<script>
    (function(){
        function parseValue(val, type){
            if (!val) return null;
            val = val.trim();
            if (type === 'number'){
                var n = parseFloat(val.replace(/,/g,''));
                return isNaN(n) ? null : n;
            }
            return val.toLowerCase();
        }

        function sortTable(table, colIndex, type, asc){
            var tbody = table.tBodies[0];
            var rows = Array.from(tbody.querySelectorAll('tr'));
            rows.sort(function(a,b){
                var aText = a.children[colIndex].innerText || '';
                var bText = b.children[colIndex].innerText || '';
                var aVal = parseValue(aText, type);
                var bVal = parseValue(bText, type);
                if (aVal === null && bVal === null) return 0;
                if (aVal === null) return 1;
                if (bVal === null) return -1;
                if (aVal < bVal) return asc ? -1 : 1;
                if (aVal > bVal) return asc ? 1 : -1;
                return 0;
            });
            rows.forEach(function(r){ tbody.appendChild(r); });
        }

        document.addEventListener('DOMContentLoaded', function(){
            var table = document.querySelector('.company-table');
            if (!table) return;
            var headers = table.querySelectorAll('th.sortable');
            headers.forEach(function(h){
                var colIndex = Array.prototype.indexOf.call(h.parentNode.children, h);
                var type = h.getAttribute('data-type') || 'string';
                var asc = true;
                h.addEventListener('click', function(){
                    headers.forEach(function(h2){ h2.classList.remove('sorted-asc','sorted-desc'); });
                    sortTable(table, colIndex, type, asc);
                    h.classList.add(asc ? 'sorted-asc' : 'sorted-desc');
                    asc = !asc;
                });
            });
        });
    })();
</script>
<script>
    (function () {
        const form = document.getElementById('companyFilterForm');
        const exportButton = document.getElementById('companyExportButton');
        const smExportButton = document.getElementById('companySmExportButton');
        const previewButton = document.getElementById('companyResetPreviewButton');
        const previewForm = previewButton ? previewButton.closest('form') : null;
        const resetButton = document.getElementById('companyResetButton');
        const resetForm = resetButton ? resetButton.closest('form') : null;
        const progressContainer = document.getElementById('companyExportProgressContainer');
        const progressBar = document.getElementById('companyExportProgressBar');
        const progressPercent = document.getElementById('companyExportProgressPercent');
        const progressLabel = document.getElementById('companyExportProgressLabel');

        if (!form || !exportButton || !smExportButton || !progressContainer || !progressBar || !progressPercent || !progressLabel) {
            return;
        }

        let timerId = null;

        function startProgress(labelText) {
            if (timerId) {
                window.clearInterval(timerId);
            }

            let value = 8;
            progressLabel.textContent = labelText;
            progressContainer.style.display = '';

            function render() {
                progressBar.style.width = value + '%';
                progressPercent.textContent = value + '%';
            }

            render();

            timerId = window.setInterval(function () {
                if (value < 90) {
                    value += 4;
                    render();
                }
            }, 250);
        }

        form.addEventListener('submit', function (event) {
            if (!event.submitter) {
                return;
            }

            if (event.submitter.id === 'companyExportButton') {
                startProgress('Exporting companies...');
            }

            if (event.submitter.id === 'companySmExportButton') {
                startProgress('Exporting SurveyMonkey file...');
            }
        });

        if (resetForm && resetButton) {
            resetForm.addEventListener('submit', function () {
                startProgress('Resetting FYE values...');
            });
        }

        if (previewForm && previewButton) {
            previewForm.addEventListener('submit', function () {
                startProgress('Building reset preview...');
            });
        }

        var globalImportForm = document.getElementById('globalImportForm');
        if (globalImportForm) {
            globalImportForm.addEventListener('submit', function () {
                startProgress('Reading file and building import preview...');
            });
        }

        var applyGlobalImportForm = document.getElementById('applyGlobalImportForm');
        if (applyGlobalImportForm) {
            applyGlobalImportForm.addEventListener('submit', function () {
                startProgress('Applying global company import...');
            });
        }
    })();
</script>

<!-- Focus on edited company row -->
<script>
    (function() {
        const focusId = @(Model.FocusId != null ? Model.FocusId.Value.ToString() : "null");
        
        if (focusId !== null) {
            const rowElement = document.getElementById('company-row-' + focusId);
            if (rowElement) {
                // Add highlight class
                rowElement.classList.add('focused-row');
                
                // Scroll into view with smooth behavior
                rowElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
                
                // Remove highlight after 3 seconds
                setTimeout(function() {
                    rowElement.classList.remove('focused-row');
                }, 3000);
            }
        }
    })();
</script>

<style>
    .focused-row {
        background-color: #fff3cd !important;
        box-shadow: inset 0 0 6px rgba(255, 193, 7, 0.3);
    }
</style>
<style>
    .company-table td.actions-col {
        white-space: nowrap;
        min-width: 260px;
        position: sticky;
        right: 0;
        z-index: 2;
        background-color: #fff;
        box-shadow: -4px 0 6px -6px rgba(0, 0, 0, 0.45);
    }
    .company-table th.actions-header {
        position: sticky;
        right: 0;
        z-index: 3;
        background-color: #212529;
        box-shadow: -4px 0 6px -6px rgba(0, 0, 0, 0.45);
    }
    .company-table.table-striped > tbody > tr:nth-of-type(odd) > td.actions-col {
        background-color: #f2f2f2;
    }
    .company-table.table-hover > tbody > tr:hover > td.actions-col {
        background-color: #f5f5f5;
    }
    @@media (max-width: 768px) {
        .company-table td.actions-col { min-width: 230px; }
    }
</style>

