@page "{id:int}/{token?}"
@model TINWeb.Pages.Company.AnswerSurveyModel
@{
    ViewData["Title"] = "Survey Answers";
    Layout = "_SurveyLayout";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="mb-3 text-center">
                @if (!string.IsNullOrWhiteSpace(Model.SurveyHeaderImageUrl))
                {
                    <img src="@Model.SurveyHeaderImageUrl" alt="Survey Header" class="img-fluid" />
                }
            </div>
            <h1>Survey Answers</h1>
            <p class="text-muted">Please complete the survey answers for the current survey year.</p>
            <hr />

            @if (Model.Submitted)
            {
                <div class="alert alert-success" role="alert">
                    Thank you. Your survey has been submitted successfully.
                </div>
            }
            else if (Model.Saved)
            {
                <div class="alert alert-info" role="alert">
                    Your answers have been saved.
                </div>
            }
            @if (Model.IsLocked)
            {
                <div class="alert alert-warning" role="alert">
                    This survey record is locked. Data changes are disabled. Please contact the Technology Investment Network.
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="alert alert-light border d-flex justify-content-between align-items-center py-2 mb-3">
                <div class="fw-semibold" id="currentSectionHeader">Section 1 of 1</div>
                <div class="small text-body-secondary" id="currentSectionSubheader"></div>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label class="form-label mb-0">Progress</label>
                    <span id="surveyProgressText" class="small text-body-secondary">0 / 0 progressed</span>
                </div>
                <div class="progress" role="progressbar" aria-label="Survey completion progress" aria-valuemin="0" aria-valuemax="100">
                    <div id="surveyProgressBar" class="progress-bar" style="width: 0%">0%</div>
                </div>
            </div>

            <form method="post" asp-route-id="@Model.Company.Id" asp-route-token="@Model.Token">
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="CompanyId" />
                <input type="hidden" asp-for="CurrentGroupIndex" id="CurrentGroupIndex" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Company Name</label>
                        <input class="form-control bg-light" value="@Model.Company.CompanyName" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Financial Year</label>
                        <input class="form-control bg-light" value="@Model.FinancialYear" readonly />
                    </div>
                </div>

                @{
                    var sectionIndexByKey = new Dictionary<string, int>(StringComparer.Ordinal);
                    var sectionTitles = new List<string>();
                    var sectionDescriptions = new List<string>();
                    var sectionGroupIds = new List<int?>();
                    var sectionImageId1 = new List<int?>();
                    var sectionImageId2 = new List<int?>();
                    var sectionImageId3 = new List<int?>();
                    var sectionTableFormat = new List<bool>();
                    var sectionRowIndexes = new List<List<int>>();

                    for (var i = 0; i < Model.Rows.Count; i++)
                    {
                        var row = Model.Rows[i];
                        var sectionKey = row.GroupId.HasValue ? $"group-{row.GroupId.Value}" : "ungrouped";

                        if (!sectionIndexByKey.TryGetValue(sectionKey, out var sectionIndex))
                        {
                            sectionIndex = sectionTitles.Count;
                            sectionIndexByKey[sectionKey] = sectionIndex;

                            sectionTitles.Add(!string.IsNullOrWhiteSpace(row.GroupTitle) ? row.GroupTitle.Trim() : "Ungrouped Questions");
                            sectionDescriptions.Add((row.GroupDescription ?? string.Empty).Trim());
                            sectionGroupIds.Add(row.GroupId);
                            sectionImageId1.Add(row.GroupImageId1);
                            sectionImageId2.Add(row.GroupImageId2);
                            sectionImageId3.Add(row.GroupImageId3);
                            sectionTableFormat.Add(row.GroupTableFormat);
                            sectionRowIndexes.Add(new List<int>());
                        }

                        if (string.IsNullOrWhiteSpace(sectionDescriptions[sectionIndex]))
                        {
                            sectionDescriptions[sectionIndex] = (row.GroupDescription ?? string.Empty).Trim();
                        }

                        sectionImageId1[sectionIndex] ??= row.GroupImageId1;
                        sectionImageId2[sectionIndex] ??= row.GroupImageId2;
                        sectionImageId3[sectionIndex] ??= row.GroupImageId3;
                        sectionRowIndexes[sectionIndex].Add(i);
                    }

                    if (sectionTitles.Count == 0)
                    {
                        sectionTitles.Add("Survey");
                        sectionDescriptions.Add(string.Empty);
                        sectionGroupIds.Add(null);
                        sectionImageId1.Add(null);
                        sectionImageId2.Add(null);
                        sectionImageId3.Add(null);
                        sectionTableFormat.Add(false);
                        sectionRowIndexes.Add(Enumerable.Range(0, Model.Rows.Count).ToList());
                    }
                }

                @for (var groupIndex = 0; groupIndex < sectionTitles.Count; groupIndex++)
                {
                    <div class="survey-group-page" data-group-index="@groupIndex" data-group-title="@sectionTitles[groupIndex]" data-group-description="@sectionDescriptions[groupIndex]" style="display:none;">
                        @{
                            var hasTitle = !string.IsNullOrWhiteSpace(sectionTitles[groupIndex]);
                            var hasDescription = !string.IsNullOrWhiteSpace(sectionDescriptions[groupIndex]);
                            var groupImageIds = new List<int>();
                            var groupId = sectionGroupIds[groupIndex];

                            if (groupId.HasValue)
                            {
                                groupImageIds = new[]
                                {
                                    sectionImageId1[groupIndex],
                                    sectionImageId2[groupIndex],
                                    sectionImageId3[groupIndex]
                                }
                                .Where(x => x.HasValue)
                                .Select(x => x!.Value)
                                .Where(x => Model.AvailableGroupImageIds.Contains(x))
                                .Distinct()
                                .ToList();
                            }

                            var hasImages = groupImageIds.Count > 0;
                            var showSectionCard = hasTitle || hasDescription || hasImages;
                        }

                        @if (showSectionCard)
                        {
                            <div class="card mb-3">
                                @if (hasTitle || hasDescription)
                                {
                                    <div class="card-header py-2">
                                        @if (hasTitle)
                                        {
                                            <div class="fw-semibold">@sectionTitles[groupIndex]</div>
                                        }
                                        @if (hasDescription)
                                        {
                                            <div class="small text-body-secondary mt-1">@sectionDescriptions[groupIndex]</div>
                                        }
                                    </div>
                                }

                                @if (hasImages && groupId.HasValue)
                                {
                                    <div class="card-body pt-3 pb-2">
                                        <div class="d-flex flex-wrap gap-3 align-items-start">
                                            @foreach (var groupImageId in groupImageIds)
                                            {
                                                var groupImageUrl = Url.Page("./AnswerSurvey", "GroupImage", new { id = Model.Company.Id, token = Model.Token, groupId = groupId.Value, imageId = groupImageId });
                                                <img src="@groupImageUrl" alt="@sectionTitles[groupIndex] image" class="img-thumbnail" style="max-width: 660px; max-height: 480px;" />
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @if (sectionTableFormat[groupIndex])
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm align-middle mb-3">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width:40%">Question</th>
                                            <th>Answer</th>
                                            <th style="width:20%">Prev Year</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var i in sectionRowIndexes[groupIndex])
                                        {
                                            var answerType = (Model.Rows[i].AnswerType ?? string.Empty).Trim();
                                            var hasPreviousYearValue = !string.IsNullOrWhiteSpace(Model.Rows[i].PreviousYearValue);
                                            var previousYearText = Model.Rows[i].PreviousYearAnswerText ?? string.Empty;
                                            var previousYearNumber = Model.Rows[i].PreviousYearAnswerNumber?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
                                            var previousYearCurrency = Model.Rows[i].PreviousYearAnswerCurrency?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;

                                            <tr class="survey-answer-row" data-row-index="@i">
                                                <td>
                                                    <div class="fw-semibold small d-flex flex-wrap align-items-baseline gap-2">
                                                        <span class="text-muted">Q@(Model.Rows[i].OrderNumber?.ToString() ?? "-")</span>
                                                        <span>@Model.Rows[i].QuestionText</span>
                                                    </div>
                                                    <input type="hidden" asp-for="Rows[i].QuestionId" />
                                                    <input type="hidden" asp-for="Rows[i].OrderNumber" />
                                                    <input type="hidden" asp-for="Rows[i].GroupId" />
                                                    <input type="hidden" asp-for="Rows[i].GroupTitle" />
                                                    <input type="hidden" asp-for="Rows[i].GroupDescription" />
                                                    <input type="hidden" asp-for="Rows[i].GroupImageId1" />
                                                    <input type="hidden" asp-for="Rows[i].GroupImageId2" />
                                                    <input type="hidden" asp-for="Rows[i].GroupImageId3" />
                                                    <input type="hidden" asp-for="Rows[i].GroupTableFormat" />
                                                    <input type="hidden" asp-for="Rows[i].QuestionText" />
                                                    <input type="hidden" asp-for="Rows[i].AnswerType" />
                                                </td>
                                                <td>
                                                    @if (answerType.Equals("Number", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <input asp-for="Rows[i].AnswerNumber" class="form-control form-control-sm" placeholder="Enter number" />
                                                        <input type="hidden" asp-for="Rows[i].AnswerText" />
                                                        <input type="hidden" asp-for="Rows[i].AnswerCurrency" />
                                                    }
                                                    else if (answerType.Equals("Currency", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <input asp-for="Rows[i].AnswerCurrency" class="form-control form-control-sm" placeholder="Enter currency" />
                                                        <input type="hidden" asp-for="Rows[i].AnswerText" />
                                                        <input type="hidden" asp-for="Rows[i].AnswerNumber" />
                                                    }
                                                    else if (answerType.Equals("SingleChoice", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <select asp-for="Rows[i].AnswerText" class="form-select form-select-sm">
                                                            <option value="">Select an option</option>
                                                            @foreach (var option in Model.Rows[i].ChoiceOptions)
                                                            {
                                                                <option value="@option">@option</option>
                                                            }
                                                        </select>
                                                        <input type="hidden" asp-for="Rows[i].AnswerNumber" />
                                                        <input type="hidden" asp-for="Rows[i].AnswerCurrency" />
                                                    }
                                                    else if (answerType.Equals("Multichoice", StringComparison.OrdinalIgnoreCase) || answerType.Equals("MultiChoice", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        if (Model.Rows[i].ChoiceOptions.Count == 0)
                                                        {
                                                            <div class="text-muted small">No options available.</div>
                                                        }
                                                        else
                                                        {
                                                            for (var optionIndex = 0; optionIndex < Model.Rows[i].ChoiceOptions.Count; optionIndex++)
                                                            {
                                                                var option = Model.Rows[i].ChoiceOptions[optionIndex];
                                                                var optionId = $"row_{i}_opt_{optionIndex}";
                                                                var isChecked = Model.Rows[i].SelectedChoices.Contains(option, StringComparer.Ordinal);
                                                                <div class="form-check form-check-inline">
                                                                    <input
                                                                        class="form-check-input"
                                                                        type="checkbox"
                                                                        name="Rows[@i].SelectedChoices"
                                                                        value="@option"
                                                                        id="@optionId"
                                                                        @(isChecked ? "checked" : null) />
                                                                    <label class="form-check-label small" for="@optionId">@option</label>
                                                                </div>
                                                            }
                                                        }
                                                        <input type="hidden" asp-for="Rows[i].AnswerText" />
                                                        <input type="hidden" asp-for="Rows[i].AnswerNumber" />
                                                        <input type="hidden" asp-for="Rows[i].AnswerCurrency" />
                                                    }
                                                    else
                                                    {
                                                        <input asp-for="Rows[i].AnswerText" class="form-control form-control-sm" placeholder="Enter answer" />
                                                        <input type="hidden" asp-for="Rows[i].AnswerNumber" />
                                                        <input type="hidden" asp-for="Rows[i].AnswerCurrency" />
                                                    }
                                                </td>
                                                <td class="text-body-secondary small">
                                                    <div class="d-flex flex-wrap align-items-center gap-2">
                                                        <span>@(Model.Rows[i].PreviousYearValue ?? "—")</span>
                                                        @if (hasPreviousYearValue)
                                                        {
                                                            <button
                                                                type="button"
                                                                class="btn btn-sm btn-outline-secondary copy-prev-year-btn"
                                                                data-row-index="@i"
                                                                data-answer-type="@answerType"
                                                                data-prev-text="@previousYearText"
                                                                data-prev-number="@previousYearNumber"
                                                                data-prev-currency="@previousYearCurrency">
                                                                Copy
                                                            </button>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            @foreach (var i in sectionRowIndexes[groupIndex])
                            {
                                var answerType = (Model.Rows[i].AnswerType ?? string.Empty).Trim();
                                var hasPreviousYearValue = !string.IsNullOrWhiteSpace(Model.Rows[i].PreviousYearValue);
                                var previousYearText = Model.Rows[i].PreviousYearAnswerText ?? string.Empty;
                                var previousYearNumber = Model.Rows[i].PreviousYearAnswerNumber?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
                                var previousYearCurrency = Model.Rows[i].PreviousYearAnswerCurrency?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;

                                <div class="mb-3 pb-3 border-bottom">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <div class="small text-muted">Question @(Model.Rows[i].OrderNumber?.ToString() ?? "-")</div>
                                            <label class="form-label fw-semibold mb-0">@Model.Rows[i].QuestionText</label>
                                        </div>
                                        <span class="badge text-bg-secondary">@Model.Rows[i].AnswerType</span>
                                    </div>

                                    <input type="hidden" asp-for="Rows[i].QuestionId" />
                                    <input type="hidden" asp-for="Rows[i].OrderNumber" />
                                    <input type="hidden" asp-for="Rows[i].GroupId" />
                                    <input type="hidden" asp-for="Rows[i].GroupTitle" />
                                    <input type="hidden" asp-for="Rows[i].GroupDescription" />
                                    <input type="hidden" asp-for="Rows[i].GroupImageId1" />
                                    <input type="hidden" asp-for="Rows[i].GroupImageId2" />
                                    <input type="hidden" asp-for="Rows[i].GroupImageId3" />
                                    <input type="hidden" asp-for="Rows[i].GroupTableFormat" />
                                    <input type="hidden" asp-for="Rows[i].QuestionText" />
                                    <input type="hidden" asp-for="Rows[i].AnswerType" />

                                    <div class="row g-3 align-items-start survey-answer-row" data-row-index="@i">
                                        <div class="col-md-8">
                                            @if (answerType.Equals("Number", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <input asp-for="Rows[i].AnswerNumber" class="form-control" placeholder="Enter number" />
                                                <input type="hidden" asp-for="Rows[i].AnswerText" />
                                                <input type="hidden" asp-for="Rows[i].AnswerCurrency" />
                                            }
                                            else if (answerType.Equals("Currency", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <input asp-for="Rows[i].AnswerCurrency" class="form-control" placeholder="Enter currency" />
                                                <input type="hidden" asp-for="Rows[i].AnswerText" />
                                                <input type="hidden" asp-for="Rows[i].AnswerNumber" />
                                            }
                                            else if (answerType.Equals("SingleChoice", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <select asp-for="Rows[i].AnswerText" class="form-select">
                                                    <option value="">Select an option</option>
                                                    @foreach (var option in Model.Rows[i].ChoiceOptions)
                                                    {
                                                        <option value="@option">@option</option>
                                                    }
                                                </select>
                                                <input type="hidden" asp-for="Rows[i].AnswerNumber" />
                                                <input type="hidden" asp-for="Rows[i].AnswerCurrency" />
                                            }
                                            else if (answerType.Equals("Multichoice", StringComparison.OrdinalIgnoreCase) || answerType.Equals("MultiChoice", StringComparison.OrdinalIgnoreCase))
                                            {
                                                if (Model.Rows[i].ChoiceOptions.Count == 0)
                                                {
                                                    <div class="text-muted small">No options available for this question.</div>
                                                }
                                                else
                                                {
                                                    for (var optionIndex = 0; optionIndex < Model.Rows[i].ChoiceOptions.Count; optionIndex++)
                                                    {
                                                        var option = Model.Rows[i].ChoiceOptions[optionIndex];
                                                        var optionId = $"row_{i}_opt_{optionIndex}";
                                                        var isChecked = Model.Rows[i].SelectedChoices.Contains(option, StringComparer.Ordinal);

                                                        <div class="form-check">
                                                            <input
                                                                class="form-check-input"
                                                                type="checkbox"
                                                                name="Rows[@i].SelectedChoices"
                                                                value="@option"
                                                                id="@optionId"
                                                                @(isChecked ? "checked" : null) />
                                                            <label class="form-check-label" for="@optionId">@option</label>
                                                        </div>
                                                    }
                                                }

                                                <input type="hidden" asp-for="Rows[i].AnswerText" />
                                                <input type="hidden" asp-for="Rows[i].AnswerNumber" />
                                                <input type="hidden" asp-for="Rows[i].AnswerCurrency" />
                                            }
                                            else
                                            {
                                                <input asp-for="Rows[i].AnswerText" class="form-control" placeholder="Enter answer" />
                                                <input type="hidden" asp-for="Rows[i].AnswerNumber" />
                                                <input type="hidden" asp-for="Rows[i].AnswerCurrency" />
                                            }
                                        </div>
                                        <div class="col-md-4 text-md-end">
                                            <div class="small text-body-secondary">prev year: @(Model.Rows[i].PreviousYearValue ?? "—")</div>
                                            @if (hasPreviousYearValue)
                                            {
                                                <button
                                                    type="button"
                                                    class="btn btn-sm btn-outline-secondary mt-1 copy-prev-year-btn"
                                                    data-row-index="@i"
                                                    data-answer-type="@answerType"
                                                    data-prev-text="@previousYearText"
                                                    data-prev-number="@previousYearNumber"
                                                    data-prev-currency="@previousYearCurrency">
                                                    Copy prev year
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <button type="button" class="btn btn-outline-secondary" id="groupPrevButton">Previous Group</button>
                    <div id="groupPaginationText" class="small text-body-secondary"></div>
                    <button type="button" class="btn btn-outline-secondary" id="groupNextButton">Next Group</button>
                </div>

                <div id="groupNumberNav" class="d-flex flex-wrap gap-2 mb-3" aria-label="Group Number Navigation"></div>

                <div class="d-flex gap-2">
                    <button type="submit" name="FormAction" value="save" class="btn btn-secondary" disabled="@(Model.IsLocked ? "disabled" : null)">Save for Later</button>
                    <button type="submit" name="FormAction" value="submit" class="btn btn-primary" disabled="@(Model.IsLocked ? "disabled" : null)">Submit Final</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            const surveyIsLocked = @Model.IsLocked.ToString().ToLowerInvariant();

            if (surveyIsLocked) {
                const editableControls = Array.from(document.querySelectorAll('.survey-answer-row input, .survey-answer-row select, .survey-answer-row textarea'));
                editableControls.forEach(function (control) {
                    if ((control.type || '').toLowerCase() === 'hidden') {
                        return;
                    }
                    control.disabled = true;
                });

                const copyButtons = Array.from(document.querySelectorAll('.copy-prev-year-btn'));
                copyButtons.forEach(function (btn) {
                    btn.disabled = true;
                });
            }

            function normalizeType(value) {
                return (value || '').trim().toLowerCase();
            }

            function isRowAnswered(row) {
                var checkboxes = row.querySelectorAll("input[type='checkbox']");
                if (checkboxes.length > 0) {
                    return Array.from(checkboxes).some(function (checkbox) { return checkbox.checked; });
                }

                var select = row.querySelector('select');
                if (select) {
                    return !!(select.value || '').trim();
                }

                var answerInput = row.querySelector("input[type='text'], input[type='number']");
                if (answerInput) {
                    return !!(answerInput.value || '').trim();
                }

                return false;
            }

            function updateProgress() {
                var rows = Array.from(document.querySelectorAll('.survey-answer-row'));
                var total = rows.length;
                var furthestAnsweredIndex = -1;

                rows.forEach(function (row, index) {
                    if (isRowAnswered(row)) {
                        furthestAnsweredIndex = index;
                    }
                });

                var progressed = furthestAnsweredIndex + 1;
                var percent = total === 0 ? 0 : Math.round((progressed / total) * 100);

                var progressBar = document.getElementById('surveyProgressBar');
                var progressText = document.getElementById('surveyProgressText');
                if (progressBar) {
                    progressBar.style.width = percent + '%';
                    progressBar.textContent = percent + '%';
                    progressBar.setAttribute('aria-valuenow', percent.toString());
                }

                if (progressText) {
                    progressText.textContent = progressed + ' / ' + total + ' progressed';
                }
            }

            function splitChoices(text) {
                if (!text) {
                    return [];
                }

                return text
                    .split(/[;,|\n\r]+/)
                    .map(function (x) { return x.trim(); })
                    .filter(function (x) { return x.length > 0; });
            }

            var groupPages = Array.from(document.querySelectorAll('.survey-group-page'));
            var groupPrevButton = document.getElementById('groupPrevButton');
            var groupNextButton = document.getElementById('groupNextButton');
            var groupPaginationText = document.getElementById('groupPaginationText');
            var groupNumberNav = document.getElementById('groupNumberNav');
            var currentSectionHeader = document.getElementById('currentSectionHeader');
            var currentSectionSubheader = document.getElementById('currentSectionSubheader');
            var currentGroupIndexInput = document.getElementById('CurrentGroupIndex');

            var currentGroupIndex = parseInt((currentGroupIndexInput && currentGroupIndexInput.value) || '0', 10);
            if (isNaN(currentGroupIndex)) {
                currentGroupIndex = 0;
            }

            function renderGroupNumberNav() {
                if (!groupNumberNav) {
                    return;
                }

                groupNumberNav.innerHTML = '';

                groupPages.forEach(function (_, pageIndex) {
                    var button = document.createElement('button');
                    button.type = 'button';
                    button.textContent = (pageIndex + 1).toString();
                    button.className = pageIndex === currentGroupIndex
                        ? 'btn btn-sm btn-primary'
                        : 'btn btn-sm btn-outline-secondary';
                    button.setAttribute('aria-label', 'Go to section ' + (pageIndex + 1));

                    button.addEventListener('click', function () {
                        showGroup(pageIndex);
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    });

                    groupNumberNav.appendChild(button);
                });
            }

            function showGroup(index) {
                if (groupPages.length === 0) {
                    if (currentSectionHeader) {
                        currentSectionHeader.textContent = 'Section 0 of 0';
                    }
                    if (currentSectionSubheader) {
                        currentSectionSubheader.textContent = '';
                    }
                    return;
                }

                currentGroupIndex = Math.max(0, Math.min(index, groupPages.length - 1));

                groupPages.forEach(function (groupPage, pageIndex) {
                    groupPage.style.display = pageIndex === currentGroupIndex ? '' : 'none';
                });

                if (groupPrevButton) {
                    groupPrevButton.disabled = currentGroupIndex <= 0;
                }

                if (groupNextButton) {
                    groupNextButton.disabled = currentGroupIndex >= groupPages.length - 1;
                }

                var sectionNumber = currentGroupIndex + 1;
                var totalSections = groupPages.length;
                var currentTitle = groupPages[currentGroupIndex].getAttribute('data-group-title') || '';

                if (groupPaginationText) {
                    groupPaginationText.textContent = 'Section ' + sectionNumber + ' of ' + totalSections;
                }

                if (currentSectionHeader) {
                    currentSectionHeader.textContent = 'Section ' + sectionNumber + ' of ' + totalSections;
                }

                if (currentSectionSubheader) {
                    currentSectionSubheader.textContent = currentTitle;
                }

                if (currentGroupIndexInput) {
                    currentGroupIndexInput.value = currentGroupIndex.toString();
                }

                renderGroupNumberNav();
            }

            if (groupPrevButton) {
                groupPrevButton.addEventListener('click', function () {
                    showGroup(currentGroupIndex - 1);
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
            }

            if (groupNextButton) {
                groupNextButton.addEventListener('click', function () {
                    showGroup(currentGroupIndex + 1);
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
            }

            document.querySelectorAll('.copy-prev-year-btn').forEach(function (button) {
                button.addEventListener('click', function () {
                    var rowIndex = button.getAttribute('data-row-index');
                    var answerType = normalizeType(button.getAttribute('data-answer-type'));
                    var prevText = button.getAttribute('data-prev-text') || '';
                    var prevNumber = button.getAttribute('data-prev-number') || '';
                    var prevCurrency = button.getAttribute('data-prev-currency') || '';

                    if (answerType === 'number') {
                        var numberInput = document.getElementById('Rows_' + rowIndex + '__AnswerNumber');
                        if (numberInput) {
                            numberInput.value = prevNumber;
                            numberInput.dispatchEvent(new Event('input', { bubbles: true }));
                            numberInput.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                        return;
                    }

                    if (answerType === 'currency') {
                        var currencyInput = document.getElementById('Rows_' + rowIndex + '__AnswerCurrency');
                        if (currencyInput) {
                            currencyInput.value = prevCurrency;
                            currencyInput.dispatchEvent(new Event('input', { bubbles: true }));
                            currencyInput.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                        return;
                    }

                    if (answerType === 'multichoice') {
                        var selectedSet = new Set(splitChoices(prevText));
                        var selector = "input[type='checkbox'][name='Rows[" + rowIndex + "].SelectedChoices']";
                        document.querySelectorAll(selector).forEach(function (checkbox) {
                            checkbox.checked = selectedSet.has((checkbox.value || '').trim());
                            checkbox.dispatchEvent(new Event('change', { bubbles: true }));
                        });
                        return;
                    }

                    var textInput = document.getElementById('Rows_' + rowIndex + '__AnswerText');
                    if (textInput) {
                        textInput.value = prevText;
                        textInput.dispatchEvent(new Event('input', { bubbles: true }));
                        textInput.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                });
            });

            document.querySelectorAll('.survey-answer-row input, .survey-answer-row select').forEach(function (control) {
                control.addEventListener('input', updateProgress);
                control.addEventListener('change', updateProgress);
            });

            showGroup(currentGroupIndex);
            updateProgress();
        })();
    </script>
}
