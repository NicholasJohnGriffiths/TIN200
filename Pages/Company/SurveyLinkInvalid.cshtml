@page
@model TINWeb.Pages.Company.SurveyLinkInvalidModel
@{
    ViewData["Title"] = "Survey Link Invalid";
    Layout = "_SurveyLayout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1>Survey Link Invalid or Expired</h1>
            <p class="text-muted mt-3">
                This survey link is invalid or has expired.
            </p>
            <p class="text-muted">
                Please contact your account representative to request a new survey link.
            </p>
            @if (!string.IsNullOrWhiteSpace(Model.Reason))
            {
                <p class="small text-body-secondary">Reference: @Model.Reason</p>
            }
            @if (Model.RequestRecorded)
            {
                <div class="alert alert-success mt-3" role="alert">
                    Your request has been recorded. Our team will send a new survey link.
                </div>
            }
            @if (Model.HasSupportEmail)
            {
                @if (Model.CompanyId.HasValue)
                {
                    <form method="post" asp-page-handler="Request" class="d-inline">
                        <input type="hidden" name="id" value="@Model.CompanyId.Value" />
                        <input type="hidden" name="reason" value="@Model.Reason" />
                        <button type="submit" class="btn btn-outline-primary mt-2 me-2">Request Survey</button>
                    </form>
                }
                else
                {
                    <a href="@Model.RequestNewLinkUrl" class="btn btn-outline-primary mt-2 me-2">Request Survey</a>
                }
            }
        </div>
    </div>
</div>

