@page
@model TINWeb.Pages.QuestionGroups.IndexModel
@{
    ViewData["Title"] = "Question Groups";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Question Groups</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="./Create" class="btn btn-primary">Add New Group</a>
        </div>
    </div>

    @if (Model.Records.Any())
    {
        <table class="table table-striped table-hover company-table">
            <thead class="table-dark">
                <tr>
                    <th>Order</th>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Image1</th>
                    <th>Image2</th>
                    <th>Image3</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model.Records)
                {
                    <tr>
                        <td>@record.OrderNumber</td>
                        <td>@record.Title</td>
                        <td>@record.Description</td>
                        <td>
                            @if (record.ImageId1.HasValue && Model.ImageDetailsById.TryGetValue(record.ImageId1.Value, out var image1))
                            {
                                <div class="small">
                                    <strong>Name:</strong>
                                    <span class="d-inline-block text-truncate align-bottom" style="max-width: 180px;" title="@image1.FileName">@image1.FileName</span>
                                </div>
                            }
                        </td>
                        <td>
                            @if (record.ImageId2.HasValue && Model.ImageDetailsById.TryGetValue(record.ImageId2.Value, out var image2))
                            {
                                <div class="small">
                                    <strong>Name:</strong>
                                    <span class="d-inline-block text-truncate align-bottom" style="max-width: 180px;" title="@image2.FileName">@image2.FileName</span>
                                </div>
                            }
                        </td>
                        <td>
                            @if (record.ImageId3.HasValue && Model.ImageDetailsById.TryGetValue(record.ImageId3.Value, out var image3))
                            {
                                <div class="small">
                                    <strong>Name:</strong>
                                    <span class="d-inline-block text-truncate align-bottom" style="max-width: 180px;" title="@image3.FileName">@image3.FileName</span>
                                </div>
                            }
                        </td>
                        <td>
                            <a asp-page="./Details" asp-route-id="@record.Id" class="btn btn-sm btn-info">View</a>
                            <a asp-page="./Edit" asp-route-id="@record.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-page="./Delete" asp-route-id="@record.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No question groups found.</div>
    }
</div>
