@page "{id:int}"
@model TINWeb.Pages.Questions.EditModel
@{
    ViewData["Title"] = "Edit Question";
}

<div class="container mt-4">
    <h1>Edit Question</h1>
    <hr />

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Record.Id" />

        <div class="form-group mb-3">
            <label asp-for="Record.OrderNumber" class="form-label"></label>
            <input asp-for="Record.OrderNumber" class="form-control" />
            <small class="form-text text-muted">Changing this value moves this question and reorders the others automatically.</small>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Record.Title" class="form-label"></label>
            <input asp-for="Record.Title" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label asp-for="Record.Description" class="form-label"></label>
            <textarea asp-for="Record.Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Record.GroupTitle" class="form-label">Group Title</label>
            <input asp-for="Record.GroupTitle" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label asp-for="Record.QuestionText" class="form-label">Question</label>
            <textarea asp-for="Record.QuestionText" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Record.AnswerType" class="form-label"></label>
            <select asp-for="Record.AnswerType" class="form-select" id="answerTypeSelect">
                @foreach (var option in Model.AnswerTypeOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
            <span asp-validation-for="Record.AnswerType" class="text-danger"></span>
        </div>

        <div class="row" id="multichoiceFields">
            <div class="col-md-3 mb-3"><input asp-for="Record.Multi1" class="form-control" placeholder="Multi 1" /></div>
            <div class="col-md-3 mb-3"><input asp-for="Record.Multi2" class="form-control" placeholder="Multi 2" /></div>
            <div class="col-md-3 mb-3"><input asp-for="Record.Multi3" class="form-control" placeholder="Multi 3" /></div>
            <div class="col-md-3 mb-3"><input asp-for="Record.Multi4" class="form-control" placeholder="Multi 4" /></div>
            <div class="col-md-3 mb-3"><input asp-for="Record.Multi5" class="form-control" placeholder="Multi 5" /></div>
            <div class="col-md-3 mb-3"><input asp-for="Record.Multi6" class="form-control" placeholder="Multi 6" /></div>
            <div class="col-md-3 mb-3"><input asp-for="Record.Multi7" class="form-control" placeholder="Multi 7" /></div>
            <div class="col-md-3 mb-3"><input asp-for="Record.Multi8" class="form-control" placeholder="Multi 8" /></div>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-page="./Index" asp-route-focusId="@Model.Record.Id" class="btn btn-secondary">Back to List</a>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            const answerTypeSelect = document.getElementById('answerTypeSelect');
            const multichoiceFields = document.getElementById('multichoiceFields');

            function toggleMultichoiceFields() {
                const isChoiceType = answerTypeSelect && (answerTypeSelect.value === 'SingleChoice' || answerTypeSelect.value === 'Multichoice');
                if (multichoiceFields) {
                    multichoiceFields.style.display = isChoiceType ? '' : 'none';
                }
            }

            if (answerTypeSelect) {
                answerTypeSelect.addEventListener('change', toggleMultichoiceFields);
            }

            toggleMultichoiceFields();
        })();
    </script>
}
