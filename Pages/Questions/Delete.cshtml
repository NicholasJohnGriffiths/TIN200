@page "{id:int}"
@model TINWorkspaceTemp.Pages.Questions.DeleteModel
@{
    ViewData["Title"] = "Delete Question";
}

<div class="container mt-4">
    <h1>Delete Question</h1>
    <h3>Are you sure you want to delete this question?</h3>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">ID</dt><dd class="col-sm-9">@Model.Record.Id</dd>
        <dt class="col-sm-3">Order</dt><dd class="col-sm-9">@Model.Record.OrderNumber</dd>
        <dt class="col-sm-3">Title</dt><dd class="col-sm-9">@Model.Record.Title</dd>
        <dt class="col-sm-3">Question</dt><dd class="col-sm-9">@Model.Record.QuestionText</dd>
    </dl>

    <form method="post">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
