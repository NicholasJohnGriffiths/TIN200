@page "{id:int}"
@model TINWorkspaceTemp.Pages.Questions.DetailsModel
@{
    ViewData["Title"] = "Question Details";
}

<div class="container mt-4">
    <h1>Question Details</h1>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">ID</dt><dd class="col-sm-9">@Model.Record.Id</dd>
        <dt class="col-sm-3">Order</dt><dd class="col-sm-9">@Model.Record.OrderNumber</dd>
        <dt class="col-sm-3">Title</dt><dd class="col-sm-9">@Model.Record.Title</dd>
        <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Record.Description</dd>
        <dt class="col-sm-3">Question</dt><dd class="col-sm-9">@Model.Record.QuestionText</dd>
        <dt class="col-sm-3">Answer Type</dt><dd class="col-sm-9">@Model.Record.AnswerType</dd>
        <dt class="col-sm-3">Multi 1-8</dt>
        <dd class="col-sm-9">@string.Join(", ", new[] { Model.Record.Multi1, Model.Record.Multi2, Model.Record.Multi3, Model.Record.Multi4, Model.Record.Multi5, Model.Record.Multi6, Model.Record.Multi7, Model.Record.Multi8 }.Where(x => !string.IsNullOrWhiteSpace(x)))</dd>
    </dl>

    <a asp-page="./Edit" asp-route-id="@Model.Record.Id" class="btn btn-warning">Edit</a>
    <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
</div>
