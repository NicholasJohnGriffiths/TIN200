@page
@model TINWeb.Pages.Questions.IndexModel
@{
    ViewData["Title"] = "Questions";
}

<div class="container-fluid px-0 mt-3">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="alert">
            @Model.StatusMessage
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Questions</h1>
            <p class="mb-0"><strong>Row count:</strong> @Model.Records.Count</p>
        </div>
        <div class="col-md-4 text-end">
            <div class="d-inline-flex gap-2">
                <a asp-page-handler="Export" class="btn btn-outline-success">SM Export</a>
                <form method="post" asp-page-handler="Reorder" class="d-inline">
                    @if (Model.FocusId.HasValue)
                    {
                        <input type="hidden" name="focusId" value="@Model.FocusId.Value" />
                    }
                    <button type="submit" class="btn btn-outline-secondary">Reorder</button>
                </form>
                <a asp-page="./Create" class="btn btn-primary">Add New Question</a>
            </div>
        </div>
    </div>

    @if (Model.Records.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover company-table questions-table">
                <thead class="table-dark">
                    <tr>
                        <th>Order</th>
                        <th>Group</th>
                        <th class="title-col">Title</th>
                        <th class="question-col">Question</th>
                        <th class="answer-type-col">Answer Type</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < Model.Records.Count; i++)
                {
                    var record = Model.Records[i];
                    var isFocused = Model.FocusId.HasValue && Model.FocusId.Value == record.Id;
                    <tr id="question-@record.Id" class="@(isFocused ? "focused-question-row" : string.Empty)">
                        <td>@record.OrderNumber</td>
                        <td>@(Model.GroupTitlesByQuestionId.TryGetValue(record.Id, out var groupTitle) ? groupTitle : string.Empty)</td>
                        <td class="title-col">@record.Title</td>
                        <td class="question-col">@record.QuestionText</td>
                        <td class="answer-type-col">@record.AnswerType</td>
                        <td class="actions-col">
                            <div class="d-inline-flex gap-1 flex-nowrap">
                                <form method="post" asp-page-handler="MoveUp" class="d-inline">
                                    <input type="hidden" name="id" value="@record.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" disabled="@(i == 0)">Up</button>
                                </form>
                                <form method="post" asp-page-handler="MoveDown" class="d-inline">
                                    <input type="hidden" name="id" value="@record.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" disabled="@(i == Model.Records.Count - 1)">Down</button>
                                </form>
                                <a asp-page="./Details" asp-route-id="@record.Id" class="btn btn-sm btn-info">View</a>
                                <a asp-page="./Edit" asp-route-id="@record.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-page="./Delete" asp-route-id="@record.Id" class="btn btn-sm btn-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No question records found.</div>
    }
</div>

<style>
    .title-col {
        width: 20%;
    }

    .question-col {
        width: 50%;
    }

    .answer-type-col {
        min-width: 140px;
        width: 140px;
    }

    .actions-col {
        white-space: nowrap;
        min-width: 200px;
    }

    .focused-question-row {
        outline: 2px solid rgba(13, 110, 253, 0.35);
        outline-offset: -2px;
    }
</style>

@if (Model.FocusId.HasValue)
{
    <script>
        (function () {
            const row = document.getElementById('question-@Model.FocusId.Value');
            if (!row) {
                return;
            }

            row.scrollIntoView({ behavior: 'smooth', block: 'center' });
            row.setAttribute('tabindex', '-1');
            row.focus({ preventScroll: true });
        })();
    </script>
}
