@page
@model TINWorkspaceTemp.Pages.Questions.IndexModel
@{
    ViewData["Title"] = "Questions";
}

<div class="container-fluid px-0 mt-3">
    <div class="row mb-3">
        <div class="col-md-8">
            <h1>Questions</h1>
            <p class="mb-0"><strong>Row count:</strong> @Model.Records.Count</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-page="./Create" class="btn btn-primary">Add New Question</a>
        </div>
    </div>

    @if (Model.Records.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Order</th>
                        <th>Title</th>
                        <th>Question</th>
                        <th>Answer Type</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < Model.Records.Count; i++)
                {
                    var record = Model.Records[i];
                    <tr>
                        <td>@record.Id</td>
                        <td>@record.OrderNumber</td>
                        <td>@record.Title</td>
                        <td>@record.QuestionText</td>
                        <td>@record.AnswerType</td>
                        <td class="actions-col">
                            <div class="d-inline-flex gap-1 flex-nowrap">
                                <form method="post" asp-page-handler="MoveUp" class="d-inline">
                                    <input type="hidden" name="id" value="@record.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" disabled="@(i == 0)">Up</button>
                                </form>
                                <form method="post" asp-page-handler="MoveDown" class="d-inline">
                                    <input type="hidden" name="id" value="@record.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" disabled="@(i == Model.Records.Count - 1)">Down</button>
                                </form>
                                <a asp-page="./Details" asp-route-id="@record.Id" class="btn btn-sm btn-info">View</a>
                                <a asp-page="./Edit" asp-route-id="@record.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-page="./Delete" asp-route-id="@record.Id" class="btn btn-sm btn-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No question records found.</div>
    }
</div>

<style>
    .actions-col {
        white-space: nowrap;
        min-width: 200px;
    }
</style>
